# FastAPI server
APP_NAME=Whitepapper_API
REDIS_PREFIX=whitepapper
CORS_ORIGINS=https://whitepapper.antk.in,http://localhost:4321
PUBLIC_SITE_URL=http://localhost:4321
PUBLIC_API_URL=http://127.0.0.1:8000


# Clerk auth
CLERK_SECRET_KEY=sk_test_xxx
CLERK_JWT_KEY=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----
CLERK_AUTHORIZED_PARTIES=https://whitepapper.antk.in,http://localhost:4321
CLERK_WEBHOOK_SIGNING_SECRET=whsec_xxx
CLERK_OAUTH_CLIENT_ID=your-clerk-oauth-client-id
CLERK_OAUTH_CLIENT_SECRET=your-clerk-oauth-client-secret
CLERK_OAUTH_DISCOVERY_URL=https://your-instance.clerk.accounts.dev/.well-known/openid-configuration
CLERK_OAUTH_REDIRECT_URI=https://api.papper.antk.in/mcp/auth/callback

# setup a firebase service account and add the JSON content here. because im using admin sdk in server. also block all read/write requests in firestore stores (for client sdk)
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIRESTORE_DATABASE_ID=(default)
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n","client_email":"...","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"..."}

# make a github actions secret varaible
CRON_SECRET=paste-cron-secret-here
# look at the yaml files, make sure to add the api base url in github as well.

# im using aiven valkey. redis.io / upstash also (should) works fine.
VALKEY_SERVICE_URI=redis://default:password@host:6379/0
VALKEY_HOST=
VALKEY_PORT=
VALKEY_USER=
VALKEY_PASSWORD=

# Groq
GROQ_API_KEY=gsk_xxx

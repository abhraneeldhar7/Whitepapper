---
import Layout from "@/layouts/Layout.astro";
import LegalDocument from "@/components/legal-document.astro";

const privacyPolicyProps = {
  "title": "Privacy Policy",
  "summary": "This Privacy Policy explains what information Whitepapper collects when you use the platform, how it is stored and protected, and your rights over that data. Whitepapper is operated by an independent developer based in Kolkata, India.",
  "effectiveDate": "April 2, 2026",
  "sections": [
    {
      "title": "Who We Are",
      "content": "Whitepapper is a content management platform available at whitepapper.antk.in, operated independently by an indie developer based in Kolkata, India. If you have any questions about this policy, you can reach out via the contact page at antk.in."
    },
    {
      "title": "What Information We Collect",
      "content": "We collect the following information when you use Whitepapper:\n\n**Account Information:** When you sign up, we collect your name, email address, and authentication details. Sign-in and sign-up is handled through Clerk, a third-party authentication service.\n\n**Content You Create:** Any projects, collections, and papers (your written content, titles, metadata, and thumbnails) that you create on Whitepapper are stored on our servers and linked to your account.\n\n**API Keys:** If you generate API keys for your projects, these are stored securely and scoped to your project.\n\n**Usage Data:** We may collect basic usage information such as which pages you visit and actions you take within the platform, to help us improve the product."
    },
    {
      "title": "How We Use Your Information",
      "content": "We use the information we collect solely to:\n\n- Provide and operate the Whitepapper platform\n- Associate your content with your account and keep it accessible to you\n- Allow you to control visibility of your content (public vs. private)\n- Improve and debug the platform\n- Respond to support or contact requests\n\nWe do not sell your data. We do not use your content for advertising."
    },
    {
      "title": "Content Visibility and Access Control",
      "content": "Whitepapper gives you full control over your content's visibility:\n\n- **Private papers** are only accessible to you as the owner. They are never shown to unauthenticated users or other accounts.\n- **Public papers** are accessible to anyone, including non-logged-in visitors and via the developer API.\n\nYou are responsible for choosing the correct visibility setting for your content before publishing."
    },
    {
      "title": "Third-Party Services",
      "content": "Whitepapper uses the following third-party services that may process some of your data as part of normal platform operation:\n\n- **Clerk** — handles user authentication (sign up, sign in, session management)\n- **Google Firebase / Firestore** — used for data storage\n- **Google Cloud Run** — used to run the backend API\n- **Groq** — may be used for AI-assisted features within the platform\n\nEach of these services has its own privacy policy. By using Whitepapper, you acknowledge that your data may be processed by these services as described in their respective policies."
    },
    {
      "title": "Data Storage and Security",
      "content": "Your data is stored on Google Cloud infrastructure. We take reasonable precautions to protect your account and content, including:\n\n- Project-scoped API keys to limit unauthorized access\n- Authentication-gated access to private content\n- HTTPS across all platform surfaces\n\nHowever, no system is completely secure. We cannot guarantee absolute security and will not be liable for unauthorized access beyond our reasonable control."
    },
    {
      "title": "Data Retention",
      "content": "Your data is retained as long as your account is active. If you wish to delete your account or specific content, you can do so from the dashboard or by contacting us. Upon deletion, your content and associated data will be removed from our active systems."
    },
    {
      "title": "Your Rights",
      "content": "As a user, you have the right to:\n\n- Access the data associated with your account\n- Correct inaccurate account information\n- Delete your content or your account at any time\n- Request a copy of your data by contacting us\n\nTo exercise any of these rights, please reach out through the contact page at antk.in."
    },
    {
      "title": "Children's Privacy",
      "content": "Whitepapper is a general-purpose content management platform with no age restriction. We do not knowingly collect data from children under the age of 13 without parental consent. If you believe a minor has created an account without consent, please contact us and we will remove the data promptly."
    },
    {
      "title": "Changes to This Policy",
      "content": "We may update this Privacy Policy from time to time. When we do, the effective date at the top of this page will be updated. Continued use of Whitepapper after changes are posted constitutes your acceptance of the revised policy. We recommend reviewing this page periodically."
    },
    {
      "title": "Contact",
      "content": "If you have any questions, concerns, or requests regarding this Privacy Policy, please reach out to [abhraneeldhar](mailto:abhraneeldhar@gmail.com)."
    }
  ]
}


---

<Layout title="Privacy Policy | Whitepapper" description="Privacy policy for Whitepapper.">
	<LegalDocument
		title={privacyPolicyProps.title}
		summary={privacyPolicyProps.summary}
		effectiveDate={privacyPolicyProps.effectiveDate}
		sections={privacyPolicyProps.sections}
	/>
</Layout>
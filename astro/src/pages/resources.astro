---
import BlogListingPage from "@/components/blogs/BlogListingPage.astro";
import Layout from "@/layouts/Layout.astro";
import { getSiteBlogCollectionBySlug } from "@/lib/api/site_blogs";

const resourcesBlogs = await getSiteBlogCollectionBySlug("resources");


Astro.response.headers.set(
  "Cache-Control",
  "public, max-age=600, s-maxage=600, stale-while-revalidate=600",
);

---

<Layout title="Latest at Whitepapper | Blogs">
    <BlogListingPage
        pageTitle="resources"
        primaryTitle="Resources"
        primaryBlogs={resourcesBlogs.papers.slice(0, 2)}
        secondaryBlogs={resourcesBlogs.papers.slice(2, resourcesBlogs.papers.length)}
    />
</Layout>

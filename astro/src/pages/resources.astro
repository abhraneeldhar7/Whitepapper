---
import SiteContentListingPage from "@/components/site/SiteContentListingPage.astro";
import Layout from "@/layouts/Layout.astro";
import { fetchDevCollectionBySlug } from "@/lib/api/contentFetcher";

const resourcesBlogs = await fetchDevCollectionBySlug("resources");

Astro.response.headers.set(
  "Cache-Control",
  "public, max-age=300, s-maxage=300, stale-while-revalidate=300",
);
---

<Layout>
  <main aria-label="Resources listing">
    <SiteContentListingPage
      pageTitle="resources"
      primaryTitle="Resources"
      backHref="/blogs"
      backLabel="Blogs"
      primaryBlogs={resourcesBlogs.papers.slice(0, 2)}
      secondaryBlogs={resourcesBlogs.papers.slice(
        2,
        resourcesBlogs.papers.length,
      )}
    />
  </main>
</Layout>

---
import Layout from "@/layouts/Layout.astro";
import ComponentDocPage from "@/components/component-docs/ComponentDocPage.astro";

import markdownDocs from "@/content/components/markdown.md?raw";
import linearDocs from "@/content/components/linear-toc.md?raw";
import mobileDocs from "@/content/components/mobile-toc.md?raw";
import linesDocs from "@/content/components/lines-toc.md?raw";

import markdownCode from "@/components/ui/markdown-render/markdown-render.tsx?raw";
import linearCode from "@/components/ui/toc/linearTableOfContent.tsx?raw";
import mobileCode from "@/components/ui/toc/mobileTableOfContent.tsx?raw";
import linesCode from "@/components/ui/toc/linesTableOfContent.tsx?raw";

const componentOrder = [
  "markdown",
  "linear-toc",
  "mobile-toc",
  "lines-toc",
] as const;
type ComponentSlug = (typeof componentOrder)[number];

const componentMeta: Record<
  ComponentSlug,
  {
    componentName: string;
    title: string;
    description: string;
    docs: string;
    code: string;
  }
> = {
  markdown: {
    componentName: "markdown",
    title: "Markdown Render",
    description:
      "A reading-first markdown renderer with copyable code blocks, GitHub-flavored markdown support, and a clean article layout.",
    docs: markdownDocs,
    code: markdownCode,
  },
  "linear-toc": {
    componentName: "linear-toc",
    title: "Linear Table Of Content",
    description:
      "A quiet, structured table-of-content rail that tracks the active heading and gives long-form pages a steady navigation spine.",
    docs: linearDocs,
    code: linearCode,
  },
  "mobile-toc": {
    componentName: "mobile-toc",
    title: "Mobile Table Of Content",
    description:
      "A compact bottom-sheet table of contents for phones that tracks progress, surfaces the current heading, and expands when readers need orientation.",
    docs: mobileDocs,
    code: mobileCode,
  },
  "lines-toc": {
    componentName: "lines-toc",
    title: "Lines Table Of Content",
    description:
      "An expressive desktop-only table-of-content rail that turns heading navigation into a visual reading instrument on the right edge of the screen.",
    docs: linesDocs,
    code: linesCode,
  },
};

export function getStaticPaths() {
  return componentOrder.map((component) => ({ params: { component } }));
}

const componentParam = Astro.params.component as ComponentSlug | undefined;
if (!componentParam || !(componentParam in componentMeta)) {
  return new Response(null, { status: 404 });
}

const active = componentMeta[componentParam];
const activeIndex = componentOrder.indexOf(componentParam);
const previousSlug = activeIndex > 0 ? componentOrder[activeIndex - 1] : null;
const nextSlug =
  activeIndex < componentOrder.length - 1
    ? componentOrder[activeIndex + 1]
    : null;
const contentContainerId = `component-doc-${componentParam}`;
const markdown = `## Code\n\n\`\`\`\`tsx\n${active.code.trim()}\n\`\`\`\`\n\n${active.docs.trim()}`;
const previous = previousSlug
  ? {
      href: `/components/${previousSlug}`,
      label: componentMeta[previousSlug].title,
    }
  : null;
const next = nextSlug
  ? { href: `/components/${nextSlug}`, label: componentMeta[nextSlug].title }
  : null;
---

<Layout>
  <ComponentDocPage
    componentName={active.componentName}
    title={active.title}
    description={active.description}
    markdown={markdown}
    contentContainerId={contentContainerId}
    previous={previous}
    next={next}
  />
</Layout>

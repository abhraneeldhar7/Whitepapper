---
import Layout from "@/layouts/Layout.astro";
import ComponentDocPage from "@/components/component-docs/ComponentDocPage.astro";

import markdownCode from "@/components/ui/markdown-render/markdown-render.tsx?raw";
import linearCode from "@/components/ui/toc/linearTableOfContent.tsx?raw";
import mobileCode from "@/components/ui/toc/mobileTableOfContent.tsx?raw";
import linesCode from "@/components/ui/toc/linesTableOfContent.tsx?raw";
import type { PaperDoc } from "@/lib/entities";
import { buildBlogPaperMetadata, buildPaperSeoConfig } from "@/metadata/dynamic";

const componentOrder = [
  "markdown",
  "linear-toc",
  "mobile-toc",
  "lines-toc",
] as const;
type ComponentSlug = (typeof componentOrder)[number];
type SitePaperResponse = {
  paper: PaperDoc;
};

const componentMeta: Record<
  ComponentSlug,
  {
    componentName: string;
    title: string;
    description: string;
    code: string;
  }
> = {
  markdown: {
    componentName: "markdown",
    title: "Markdown Render",
    description:
      "A reading-first markdown renderer with copyable code blocks, GitHub-flavored markdown support, and a clean article layout.",
    code: markdownCode,
  },
  "linear-toc": {
    componentName: "linear-toc",
    title: "Linear Table Of Content",
    description:
      "A quiet, structured table-of-content rail that tracks the active heading and gives long-form pages a steady navigation spine.",
    code: linearCode,
  },
  "mobile-toc": {
    componentName: "mobile-toc",
    title: "Mobile Table Of Content",
    description:
      "A compact bottom-sheet table of contents for phones that tracks progress, surfaces the current heading, and expands when readers need orientation.",
    code: mobileCode,
  },
  "lines-toc": {
    componentName: "lines-toc",
    title: "Lines Table Of Content",
    description:
      "An expressive desktop-only table-of-content rail that turns heading navigation into a visual reading instrument on the right edge of the screen.",
    code: linesCode,
  },
};

export function getStaticPaths() {
  return componentOrder.map((component) => ({ params: { component } }));
}

const componentParam = Astro.params.component as ComponentSlug | undefined;
if (!componentParam || !(componentParam in componentMeta)) {
  return new Response(null, { status: 404 });
}

const active = componentMeta[componentParam];
const activeIndex = componentOrder.indexOf(componentParam);
const previousSlug = activeIndex > 0 ? componentOrder[activeIndex - 1] : null;
const nextSlug =
  activeIndex < componentOrder.length - 1
    ? componentOrder[activeIndex + 1]
    : null;
const contentContainerId = `component-doc-${componentParam}`;
const previous = previousSlug
  ? {
      href: `/components/${previousSlug}`,
      label: componentMeta[previousSlug].title,
    }
  : null;
const next = nextSlug
  ? { href: `/components/${nextSlug}`, label: componentMeta[nextSlug].title }
  : null;

Astro.response.headers.set(
  "Cache-Control",
  "public, max-age=600, s-maxage=600, stale-while-revalidate=600",
);
Astro.response.headers.set(
  "CDN-Cache-Control",
  "public, max-age=600, stale-while-revalidate=600",
);

const apiBaseUrl = String(import.meta.env.PUBLIC_API_BASE_URL ?? "")
  .trim()
  .replace(/\/+$/, "");
const whitepapperApiKey = String(import.meta.env.WHITEPAPPER_API_KEY ?? "").trim();
const siteUrl = String(import.meta.env.PUBLIC_SITE_URL ?? "")
  .trim()
  .replace(/\/+$/, "");

if (!apiBaseUrl || !whitepapperApiKey) {
  throw new Error("PUBLIC_API_BASE_URL and WHITEPAPPER_API_KEY must be configured in Astro env.");
}

const componentPaperSlugByRoute: Record<ComponentSlug, string> = {
  markdown: "components-markdown",
  "linear-toc": "components-linear-toc",
  "mobile-toc": "components-mobile-toc",
  "lines-toc": "components-lines-toc",
};

const componentPaperSlug = componentPaperSlugByRoute[componentParam];
const paperResponse = await fetch(
  `${apiBaseUrl}/dev/paper?slug=${encodeURIComponent(componentPaperSlug)}`,
  {
    method: "GET",
    headers: {
      accept: "application/json",
      "x-api-key": whitepapperApiKey,
    },
  },
);

if (!paperResponse.ok) {
  const message = await paperResponse.text();
  throw new Error(message || `Upstream request failed with ${paperResponse.status}`);
}

const { paper } = (await paperResponse.json()) as SitePaperResponse;
const markdown = `## Code\n\n\`\`\`\`tsx\n${active.code.trim()}\n\`\`\`\`\n\n${(paper.body || "").trim()}`;
const resolvedSiteUrl = siteUrl || Astro.url.origin.replace(/\/+$/, "");
const metadata = {
  ...buildBlogPaperMetadata({ paper, siteUrl: resolvedSiteUrl }),
  canonical: `${resolvedSiteUrl}/components/${active.componentName}`,
};

const seo = buildPaperSeoConfig(metadata, {
  schemaType: "Article",
  breadcrumbItems: [
    {
      position: 1,
      name: "Components",
      item: `${resolvedSiteUrl}/components`,
    },
    {
      position: 2,
      name: metadata.headline,
      item: metadata.canonical,
    },
  ],
});
---

<Layout seo={seo}>
  <ComponentDocPage
    componentName={active.componentName}
    title={active.title}
    description={active.description}
    markdown={markdown}
    contentContainerId={contentContainerId}
    previous={previous}
    next={next}
  />
</Layout>


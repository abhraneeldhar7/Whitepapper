---
import Layout from "@/layouts/Layout.astro";
import LegalDocument from "@/components/legal-document.astro";

const termsOfServiceProps = {
  "title": "Terms of Service",
  "summary": "These Terms of Service govern your use of Whitepapper, a content management platform operated by an independent developer at whitepapper.antk.in. By using the platform, you agree to these terms.",
  "effectiveDate": "April 2, 2026",
  "sections": [
    {
      "title": "Acceptance of Terms",
      "content": "By accessing or using Whitepapper at whitepapper.antk.in, you agree to be bound by these Terms of Service. If you do not agree, please do not use the platform.\n\nWhitepapper is operated by an independent developer based in Kolkata, India. These terms are governed by the laws of India, including the Information Technology Act, 2000 and applicable rules thereunder."
    },
    {
      "title": "What Whitepapper Is",
      "content": "Whitepapper is a content management platform that lets you create, organize, and publish written content. It provides:\n\n- A markdown-first editor for writing\n- Project and collection-based content organization\n- SEO metadata management\n- A developer API for reading your content externally\n- Distribution tools for publishing content to other platforms\n\nThe platform is provided as-is by an indie developer and is actively being developed. Features may change over time."
    },
    {
      "title": "Your Account",
      "content": "To use Whitepapper, you must create an account. You are responsible for:\n\n- Keeping your login credentials secure\n- All activity that occurs under your account\n- Not sharing your account with others\n\nWe reserve the right to suspend or terminate accounts that violate these terms or that are found to be engaged in abusive or harmful activity."
    },
    {
      "title": "Your Content",
      "content": "You retain full ownership of all content you create on Whitepapper — your projects, collections, papers, and any other material you upload or write.\n\nBy using Whitepapper, you grant us a limited, non-exclusive license to store, display, and serve your content solely for the purpose of operating the platform on your behalf. We do not claim ownership of your content and do not use it for any purpose outside of providing the service.\n\nYou are solely responsible for the content you publish. You must ensure your content does not:\n\n- Violate any applicable laws\n- Infringe on the intellectual property rights of others\n- Contain harmful, abusive, defamatory, or unlawful material"
    },
    {
      "title": "Content Visibility",
      "content": "Whitepapper gives you control over who can see your content:\n\n- **Private papers** are only visible to you when logged in.\n- **Public papers** are visible to anyone, including visitors who are not logged in and external systems using the developer API.\n\nYou are solely responsible for setting the correct visibility on your content. We are not liable for content you accidentally publish publicly."
    },
    {
      "title": "Developer API and API Keys",
      "content": "Whitepapper provides a developer API for reading your project content externally. API keys are project-scoped and are your responsibility to manage securely.\n\n- Do not share your API keys publicly (e.g., in public repositories)\n- You are responsible for any usage that occurs via your API key\n- We reserve the right to revoke API keys that are found to be misused\n\nThe API is currently read-oriented and provided as a developer convenience. Its behavior and availability may change as the platform evolves."
    },
    {
      "title": "Prohibited Use",
      "content": "You may not use Whitepapper to:\n\n- Upload or publish content that is illegal under Indian law or international law\n- Infringe on copyrights, trademarks, or other intellectual property\n- Attempt to access other users' private content without authorization\n- Reverse-engineer, scrape, or abuse the platform or its API\n- Use the platform to send spam or unsolicited communications\n- Interfere with the stability or security of the platform\n\nViolation of these prohibitions may result in immediate account suspension."
    },
    {
      "title": "No Payments (Currently)",
      "content": "Whitepapper does not currently charge for its services. No payment information is collected or processed. This may change in the future, at which point updated terms will be published and users will be notified."
    },
    {
      "title": "Third-Party Integrations",
      "content": "Whitepapper connects with third-party platforms (such as Hashnode, Medium, and others) as distribution channels. When you use these integrations, you are also subject to the terms of service of those platforms. We are not responsible for the actions, policies, or availability of third-party services."
    },
    {
      "title": "Availability and Uptime",
      "content": "Whitepapper is operated by a single independent developer. We do not guarantee any specific level of uptime or availability. The platform may go down for maintenance, bug fixes, or due to factors outside our control. We are not liable for losses resulting from downtime or unavailability."
    },
    {
      "title": "Limitation of Liability",
      "content": "To the maximum extent permitted by applicable law, Whitepapper and its operator shall not be liable for:\n\n- Loss of content, data, or access\n- Indirect, incidental, or consequential damages\n- Losses arising from third-party service failures (Clerk, Firebase, Groq, etc.)\n- Losses resulting from your own misconfiguration of content visibility\n\nYour use of Whitepapper is at your own risk."
    },
    {
      "title": "Modifications to the Platform and Terms",
      "content": "We reserve the right to modify, suspend, or discontinue any part of Whitepapper at any time. We also reserve the right to update these Terms of Service. When we do, the effective date will be updated at the top of this page.\n\nContinued use of the platform after changes are posted means you accept the updated terms."
    },
    {
      "title": "Governing Law",
      "content": "These Terms of Service are governed by the laws of India. Any disputes arising from the use of Whitepapper shall be subject to the jurisdiction of courts located in Kolkata, West Bengal, India."
    },
    {
      "title": "Contact",
      "content": "For any questions, concerns, or reports related to these Terms of Service, please reach out through the contact page at [antk.in](https://antk.in)."
    }
  ]
}
---

<Layout
	title="Terms of Service | Whitepapper"
	description="Terms of service for Whitepapper."
>
	<LegalDocument
		title={termsOfServiceProps.title}
		summary={termsOfServiceProps.summary}
		effectiveDate={termsOfServiceProps.effectiveDate}
		sections={termsOfServiceProps.sections}
	/>
</Layout>

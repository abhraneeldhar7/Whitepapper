---
import Layout from "@/layouts/Layout.astro";
import SiteContentListingPage from "@/components/site/SiteContentListingPage.astro";
import { fetchDevCollectionBySlug } from "@/lib/api/contentFetcher";

const comparePages = await fetchDevCollectionBySlug("compare");

Astro.response.headers.set(
  "Cache-Control",
  "public, max-age=300, s-maxage=300, stale-while-revalidate=300",
);
---

<Layout>
  <main aria-label="Compare listing">
    <SiteContentListingPage
      pageTitle="compare"
      primaryTitle="Compare"
      backHref="/"
      backLabel="Home"
      primaryPapers={comparePages.papers}
    />
  </main>
</Layout>

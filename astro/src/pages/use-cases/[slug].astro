---
import SiteContentPaperPage from "@/components/site/SiteContentPaperPage.astro";
import type { PaperDoc } from "@/lib/entities";
import { buildBlogPaperMetadata, buildPaperSeoConfig } from "@/metadata/dynamic";

type SiteCollectionResponse = {
  papers: PaperDoc[];
};

const pageSlug = Astro.params.slug as string;
const normalizedSlug = pageSlug.trim().toLowerCase();
const siteUrl = String(import.meta.env.PUBLIC_SITE_URL ?? "")
  .trim()
  .replace(/\/+$/, "");

if (pageSlug !== normalizedSlug) {
  return Astro.redirect(`/use-cases/${normalizedSlug}`, 301);
}

Astro.response.headers.set(
  "Cache-Control",
  "public, max-age=600, s-maxage=600, stale-while-revalidate=600",
);
Astro.response.headers.set(
  "CDN-Cache-Control",
  "public, max-age=600, stale-while-revalidate=600",
);

const apiBaseUrl = String(import.meta.env.PUBLIC_API_BASE_URL ?? "")
  .trim()
  .replace(/\/+$/, "");
const whitepapperApiKey = String(import.meta.env.WHITEPAPPER_API_KEY ?? "").trim();

if (!apiBaseUrl || !whitepapperApiKey) {
  throw new Error("PUBLIC_API_BASE_URL and WHITEPAPPER_API_KEY must be configured in Astro env.");
}

const collectionResponse = await fetch(
  `${apiBaseUrl}/dev/collection?slug=${encodeURIComponent("use-cases")}`,
  {
    method: "GET",
    headers: {
      accept: "application/json",
      "x-api-key": whitepapperApiKey,
    },
  },
);

if (!collectionResponse.ok) {
  const message = await collectionResponse.text();
  throw new Error(message || `Upstream request failed with ${collectionResponse.status}`);
}

const { papers } = (await collectionResponse.json()) as SiteCollectionResponse;
const paper = papers.find((entry) => entry.slug === normalizedSlug);

if (!paper) {
  return new Response(null, { status: 404 });
}

if (paper.slug !== normalizedSlug) {
  return Astro.redirect(`/use-cases/${paper.slug}`, 301);
}

const resolvedSiteUrl = siteUrl || Astro.url.origin.replace(/\/+$/, "");
const metadata = {
  ...buildBlogPaperMetadata({ paper, siteUrl: resolvedSiteUrl }),
  canonical: `${resolvedSiteUrl}/use-cases/${normalizedSlug}`,
};

const seo = buildPaperSeoConfig(metadata, {
  schemaType: "Article",
  breadcrumbItems: [
    {
      position: 1,
      name: "Use Cases",
      item: `${resolvedSiteUrl}/use-cases`,
    },
    {
      position: 2,
      name: metadata.headline,
      item: metadata.canonical,
    },
  ],
});
---

<SiteContentPaperPage
  paper={paper}
  metadata={metadata}
  parentHref="/use-cases"
  parentLabel="Use Cases"
  seo={seo}
/>


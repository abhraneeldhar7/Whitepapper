---
import WriteEditor from "@/components/write/WriteEditor";
import WriteEditorSkeleton from "@/components/write/WriteEditorSkeleton";
import Layout from "@/layouts/Layout.astro";
import { createApiClient } from "@/lib/api/client";
import { getPaper } from "@/lib/api/papers";
import type { PaperDoc } from "@/lib/entities";
import { isMobileUserAgent } from "@/lib/userAgent";

const { getToken } = Astro.locals.auth();
const id = Astro.params.id as string;

const isMobileUA = isMobileUserAgent(Astro.request.headers.get("user-agent"));

const serverClient = createApiClient(getToken);
let initialPaper: PaperDoc;
try {
  initialPaper = await getPaper(id, serverClient);
} catch {
  return Astro.redirect("/404");
}
---

<Layout showSiteNav={false} noindex={true}>
  <WriteEditor
    client:only="react"
    initialPaper={initialPaper}
    isMobileUA={isMobileUA}
  >
    <WriteEditorSkeleton slot="fallback" />
  </WriteEditor>
</Layout>


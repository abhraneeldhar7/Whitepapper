---
import WriteEditor from "@/components/write/WriteEditor";
import WriteEditorSkeleton from "@/components/write/WriteEditorSkeleton";
import Layout from "@/layouts/Layout.astro";
import { createApiClient } from "@/lib/api/client";
import { resolveIntegrationBaseUrl } from "@/lib/integrationBaseUrl";
import { getPaper } from "@/lib/api/papers";
import { getCurrentUser } from "@/lib/api/users";
import type { PaperDoc, UserDoc } from "@/lib/entities";
import { isMobileUserAgent } from "@/lib/userAgent";

const { getToken } = Astro.locals.auth();
const id = Astro.params.id as string;

const token = await getToken();
const isMobileUA = isMobileUserAgent(Astro.request.headers.get("user-agent"));

const serverClient = createApiClient(token);
const initialUser = await getCurrentUser(serverClient).catch(() => null as UserDoc | null);
let initialPaper: PaperDoc;
try {
  initialPaper = await getPaper(id, serverClient);
} catch (error) {
  const message = error instanceof Error ? error.message : "";
  return Astro.redirect(message.includes("403") || message.includes("Not allowed") ? "/unauthorized" : "/404");
}

const integrationBaseUrl = resolveIntegrationBaseUrl();
---

<Layout showSiteNav={false} noindex={true}>
  <WriteEditor
    client:only="react"
    initialPaper={initialPaper}
    initialUser={initialUser}
    integrationBaseUrl={integrationBaseUrl}
    isMobileUA={isMobileUA}
  >
    <WriteEditorSkeleton slot="fallback" />
  </WriteEditor>
</Layout>


---
import AboutImg from "@/assets/aboutsImg.jpg";
import Layout from "@/layouts/Layout.astro";
---

<Layout title="About | Whitepapper" description="Learn about Whitepapper, our mission, and the platform we are building.">
    <main class="max-w-[900px] mx-auto w-full]" aria-label="About Whitepapper">
        <section class="relative" aria-labelledby="about-title">
            <h1
                id="about-title"
                class="text-[40px] font-[500] absolute top-[50%] left-[50%] translate-y-[-50%] translate-x-[-50%] z-2"
            >
                About Us
            </h1>
            <img
                src={AboutImg.src}
                alt="Abstract Whitepapper about section background"
                class="h-full w-full invert dark:invert-0"
            />
        </section>

        <section class="mt-10 px-4 flex flex-col gap-5" aria-label="About details">
            <article class="flex gap-3 md:gap-5 md:flex-row flex-col">
                <h2 class="text-[20px] md:text-[24px] md:flex-1">
                    What is Whitepapper

---
import Layout from '@/layouts/Layout.astro';
import PublicProjectPage from '@/components/project/PublicProjectPage';
import { createApiClient } from '@/lib/api/client';
import { getPublicProjectBySlug } from '@/lib/api/public';
import { getCurrentUser } from '@/lib/api/users';
import { formatFirestoreDate } from '@/lib/utils';
import { isReservedUsername } from '@/lib/reservedPaths';
import { excerpt, fallbackDescription, resolveSiteUrl } from '@/lib/seo';
import { buildProjectSeo } from '@/metadata/dynamic';

const { handle: routeHandle, projectSlug } = Astro.params;
const rawHandle = (routeHandle as string).trim();
const handle = rawHandle.toLowerCase();

if (!handle || rawHandle.includes("@") || isReservedUsername(handle)) {
  return new Response(null, { status: 404 });
}

if (rawHandle !== handle) {
  return Astro.redirect(`/${handle}/p/${projectSlug}`, 301);
}

let data: Awaited<ReturnType<typeof getPublicProjectBySlug>>;
try {
  data = await getPublicProjectBySlug(handle, projectSlug as string);
} catch (error) {
  const message = error instanceof Error ? error.message : "";
  if (message.includes("403") || message.includes("Not allowed")) {
    return Astro.redirect("/unauthorized", 302);
  }
  return new Response(null, { status: 404 });
}

if (!data?.project) {
  return new Response(null, { status: 404 });
}

const owner = data.user ?? null;
const projectCreatedDate = data.project.createdAt ? formatFirestoreDate(data.project.createdAt) : null;
const siteUrl = resolveSiteUrl(import.meta.env.PUBLIC_SITE_URL, Astro.url.origin);
const ownerName = (owner?.displayName || owner?.username || handle).trim();
const description = excerpt(
  fallbackDescription(data.project.description, `${data.project.name} project page on Whitepapper.`),
);
const logoUrl = String(data.project.logoUrl || '').trim() || `${siteUrl}/appLogo.png`;
const seo = buildProjectSeo({
  siteUrl,
  handle,
  ownerName,
  description,
  project: data.project,
  papers: data.papers ?? [],
  logoUrl,
});

const { userId, getToken } = Astro.locals.auth();

let currentUserId: string | null = null;
if (userId) {
  const token = await getToken();
  if (token) {
    const serverClient = createApiClient(token);
    const currentUser = await getCurrentUser(serverClient).catch(() => null);
    currentUserId = currentUser?.userId ?? null;
  }
}
---

<Layout showSiteNav={false} seo={seo}>
  <section class="sr-only" aria-label="Project paper links">
    {
      (data.collectionPapers ?? []).flatMap((entry) =>
        (entry.papers ?? []).map((paper) => (
          <a href={`/${handle}/${paper.slug}`}>{paper.title}</a>
        )),
      )
    }
  </section>
  <PublicProjectPage
    client:idle
    handle={handle}
    project={data.project}
    papers={data.papers ?? []}
    collections={data.collections ?? []}
    collectionPapers={data.collectionPapers ?? []}
    owner={owner}
    projectCreatedDate={projectCreatedDate}
    currentUserId={currentUserId}
  />
</Layout>

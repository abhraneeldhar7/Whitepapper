---
import Layout from "@/layouts/Layout.astro";
import { getPublicPaperPageData } from "@/lib/api/public";
import { formatFirestoreDate } from "@/lib/utils";
import PostPreviewServer from "@/components/pre_made_components/render/PostPreviewServer.astro";
import type { PaperDoc, PaperMetadata } from "@/lib/types";

const handle = Astro.params.handle as string;
const pageSlug = Astro.params.slug as string;
const normalizedHandle = handle.replace(/^@+/, "").trim().toLowerCase();
const siteUrl = String(import.meta.env.PUBLIC_SITE_URL ?? "").trim().replace(/\/+$/, "");

Astro.response.headers.set(
  "Cache-Control",
  "public, max-age=600, s-maxage=600, stale-while-revalidate=600",
);

function stripMarkdown(value: string): string {
  return value
    .replace(/```[\s\S]*?```/g, " ")
    .replace(/`[^`]+`/g, " ")
    .replace(/!\[[^\]]*]\([^)]+\)/g, " ")
    .replace(/\[([^\]]+)\]\([^)]+\)/g, "$1")
    .replace(/[#>*_~\-]/g, " ")
    .replace(/\s+/g, " ")
    .trim();
}

function truncate(value: string, max: number): string {
  const normalized = value.replace(/\s+/g, " ").trim();
  if (normalized.length <= max) return normalized;
  const clipped = normalized.slice(0, max - 1).trimEnd();
  const cut = clipped.lastIndexOf(" ");
  return `${(cut > max / 2 ? clipped.slice(0, cut) : clipped).trim()}...`;
}

function asIso(value: string | null | undefined): string {
  if (!value) return new Date().toISOString();
  const date = new Date(value);
  return Number.isNaN(date.getTime()) ? new Date().toISOString() : date.toISOString();
}

function extractFirstImageUrl(body: string): string {
  if (!body) return "";
  const markdownMatch = body.match(/!\[[^\]]*]\(([^)\s]+)\)/i);
  if (markdownMatch?.[1]) return markdownMatch[1].trim();
  const htmlMatch = body.match(/<img[^>]+src=["']([^"']+)["']/i);
  if (htmlMatch?.[1]) return htmlMatch[1].trim();
  return "";
}


let paper: PaperDoc;
({ paper } = await getPublicPaperPageData(normalizedHandle, pageSlug));
const publishedDate = formatFirestoreDate(paper.createdAt);

const metadataAuthorUrlRaw = paper.metadata?.authorUrl || "";
const metadataAuthorHandle = metadataAuthorUrlRaw.split("/").filter(Boolean).pop() || normalizedHandle;
const authorHandle = metadataAuthorHandle.replace(/^@+/, "").trim().toLowerCase();
const resolvedSiteUrl = siteUrl || Astro.url.origin.replace(/\/+$/, "");
const publisherUrl = resolvedSiteUrl;
const fallbackCanonical = `${resolvedSiteUrl}/${authorHandle}/${paper.slug}`;
const fallbackImage = paper.thumbnailUrl || extractFirstImageUrl(paper.body || "") || "";
const fallbackDescription = truncate(
  `${paper.title}. ${stripMarkdown(paper.body || "")}`.trim(),
  160,
);
const fallbackTags = Array.from(
  new Set(
    `${paper.title} ${paper.slug}`
      .toLowerCase()
      .split(/[^a-z0-9]+/)
      .filter((part) => part.length > 2),
  ),
).slice(0, 6);

const metadata: PaperMetadata = paper.metadata ?? {
  title: `${paper.title} - by ${authorHandle} | Whitepapper`,
  metaDescription: fallbackDescription,
  canonical: fallbackCanonical,
  robots: paper.status === "published" ? "index, follow" : "noindex, nofollow",
  ogTitle: paper.title,
  ogDescription: truncate(fallbackDescription, 180),
  ogImage: fallbackImage,
  ogImageWidth: 1200,
  ogImageHeight: 630,
  ogImageAlt: `Cover image for ${paper.title}`,
  ogLocale: "en_US",
  ogPublishedTime: asIso(paper.createdAt),
  ogModifiedTime: asIso(paper.updatedAt),
  ogAuthorUrl: `${resolvedSiteUrl}/${authorHandle}`,
  ogTags: fallbackTags.length ? fallbackTags : ["whitepaper"],
  twitterTitle: paper.title,
  twitterDescription: truncate(fallbackDescription, 160),
  twitterImage: fallbackImage,
  twitterImageAlt: `Cover image for ${paper.title}`,
  twitterCreator: null,
  headline: paper.title,
  abstract: truncate(stripMarkdown(paper.body || "") || paper.title, 320),
  keywords: (fallbackTags.length ? fallbackTags : ["whitepaper"]).join(", "),
  articleSection: "General",
  wordCount: stripMarkdown(paper.body || "").split(/\s+/).filter(Boolean).length,
  inLanguage: "en",
  datePublished: asIso(paper.createdAt),
  dateModified: asIso(paper.updatedAt),
  authorName: authorHandle,
  authorUrl: `${resolvedSiteUrl}/${authorHandle}`,
  authorId: paper.ownerId || "",
  coverImageUrl: fallbackImage,
  isAccessibleForFree: true,
  license: "https://creativecommons.org/licenses/by/4.0/",
};
const ogTags = Array.isArray(metadata.ogTags) ? metadata.ogTags : [];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: metadata.headline,
  description: metadata.metaDescription,
  abstract: metadata.abstract,
  keywords: metadata.keywords,
  articleSection: metadata.articleSection,
  wordCount: metadata.wordCount,
  inLanguage: metadata.inLanguage,
  isAccessibleForFree: metadata.isAccessibleForFree,
  license: metadata.license,
  url: metadata.canonical,
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": metadata.canonical,
  },
  datePublished: metadata.datePublished,
  dateModified: metadata.dateModified,
  author: {
    "@type": "Person",
    name: metadata.authorName,
    url: metadata.authorUrl,
    identifier: metadata.authorId,
  },
  image: {
    "@type": "ImageObject",
    url: metadata.coverImageUrl,
    width: metadata.ogImageWidth,
    height: metadata.ogImageHeight,
  },
  publisher: {
    "@type": "Organization",
    name: "Whitepaper",
    url: publisherUrl,
    logo: {
      "@type": "ImageObject",
      url: `${publisherUrl}/logo.png`,
      width: 200,
      height: 60,
    },
  },
};

---
<Layout title={metadata.title}>
  <Fragment slot="head">
    <meta name="description" content={metadata.metaDescription} />
    <meta name="keywords" content={metadata.keywords} />
    <meta name="robots" content={metadata.robots} />
    <link rel="canonical" href={metadata.canonical} />

    <meta property="og:type" content="article" />
    <meta property="og:site_name" content="Whitepaper" />
    <meta property="og:title" content={metadata.ogTitle} />
    <meta property="og:description" content={metadata.ogDescription} />
    <meta property="og:url" content={metadata.canonical} />
    <meta property="og:image" content={metadata.ogImage} />
    <meta property="og:image:width" content={String(metadata.ogImageWidth)} />
    <meta property="og:image:height" content={String(metadata.ogImageHeight)} />
    <meta property="og:image:alt" content={metadata.ogImageAlt} />
    <meta property="og:locale" content={metadata.ogLocale} />
    <meta property="article:published_time" content={metadata.ogPublishedTime} />
    <meta property="article:modified_time" content={metadata.ogModifiedTime} />
    <meta property="article:author" content={metadata.ogAuthorUrl} />
    {
      ogTags.map((tag) => (
        <meta property="article:tag" content={tag} />
      ))
    }

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={metadata.twitterTitle} />
    <meta name="twitter:description" content={metadata.twitterDescription} />
    <meta name="twitter:image" content={metadata.twitterImage} />
    <meta name="twitter:image:alt" content={metadata.twitterImageAlt} />
    {metadata.twitterCreator ? <meta name="twitter:creator" content={metadata.twitterCreator} /> : null}

    <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <main
    class="mx-auto min-h-screen max-w-[700px] px-[15px] pt-[15px] pb-20 md:pt-6"
  >
    <h1
      class="text-[28px] md:text-[35px] font-[600] font-[]"
      style={{ lineHeight: "1.4em" }}
    >
      {paper.title}
    </h1>

    <div class="mt-4 flex items-center justify-between gap-3">
      {
        <a
          href={metadata.authorUrl || `/${authorHandle}`}
          class="flex items-center gap-[8px] w-fit"
        >
          {/* Avatar temporarily hidden */}
          <p class="text-[14px] text-muted-foreground hover:text-foreground transition-all duration-300">
          - {metadata.authorName || authorHandle}
          </p>
        </a>
      }

      {
        publishedDate ? (
          <p class="text-[14px] text-muted-foreground">{publishedDate}</p>
        ) : null
      }
    </div>

    {
      paper.thumbnailUrl ? (
        <div class="mt-6 border rounded-[8px] overflow-hidden">
          <img
            src={paper.thumbnailUrl}
            alt={paper.title}
            class="h-full w-full object-contain"
            loading="eager"
            decoding="async"
            fetchpriority="high"
          />
        </div>
      ) : null
    }

    <div class="mt-6">
      <PostPreviewServer content={paper.body} showTOC={true} />
    </div>
  </main>
</Layout>

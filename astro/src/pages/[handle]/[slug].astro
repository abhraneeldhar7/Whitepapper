---
import Layout from "@/layouts/Layout.astro";
import { getPublicPaperPageData } from "@/lib/api/public";
import { formatFirestoreDate } from "@/lib/utils";
import PostPreviewServer from "@/components/pre_made_components/render/PostPreviewServer.astro";
import type { PaperDoc, PaperMetadata } from "@/lib/types";
import { DotIcon } from "lucide-react";

const handle = Astro.params.handle as string;
const pageSlug = Astro.params.slug as string;
const normalizedHandle = handle.replace(/^@+/, "").trim().toLowerCase();
const normalizedSlug = pageSlug.trim().toLowerCase();
const siteUrl = String(import.meta.env.PUBLIC_SITE_URL ?? "")
  .trim()
  .replace(/\/+$/, "");

if (handle !== normalizedHandle || pageSlug !== normalizedSlug) {
  return Astro.redirect(`/${normalizedHandle}/${normalizedSlug}`, 301);
}

Astro.response.headers.set(
  "Cache-Control",
  "public, max-age=600, s-maxage=600, stale-while-revalidate=600",
);

let paper: PaperDoc;
({ paper } = await getPublicPaperPageData(normalizedHandle, normalizedSlug));
const updatedDate = formatFirestoreDate(paper.updatedAt);
const metadataInput = paper.metadata;
const resolvedSiteUrl = siteUrl || Astro.url.origin.replace(/\/+$/, "");
const authorHandle = (metadataInput?.authorHandle || normalizedHandle)
  .replace(/^@+/, "")
  .trim()
  .toLowerCase();
const fallbackCanonical = `${resolvedSiteUrl}/${normalizedHandle}/${paper.slug}`;
const fallbackAuthorUrl = `${resolvedSiteUrl}/${authorHandle}`;
const fallbackImage = paper.thumbnailUrl || `${resolvedSiteUrl}/appLogo.png`;
const fallbackIso = new Date().toISOString();
const metadata: PaperMetadata = {
  title: metadataInput?.title || `${paper.title} | Whitepapper`,
  metaDescription: metadataInput?.metaDescription || paper.title,
  canonical: metadataInput?.canonical || fallbackCanonical,
  robots:
    metadataInput?.robots ||
    (paper.status === "published" ? "index, follow" : "noindex, nofollow"),
  ogTitle: metadataInput?.ogTitle || paper.title,
  ogDescription:
    metadataInput?.ogDescription ||
    metadataInput?.metaDescription ||
    paper.title,
  ogImage: metadataInput?.ogImage || fallbackImage,
  ogImageWidth: metadataInput?.ogImageWidth || 1200,
  ogImageHeight: metadataInput?.ogImageHeight || 630,
  ogImageAlt: metadataInput?.ogImageAlt || `Cover image for ${paper.title}`,
  ogLocale: metadataInput?.ogLocale || "en_US",
  ogPublishedTime:
    metadataInput?.ogPublishedTime ||
    metadataInput?.datePublished ||
    fallbackIso,
  ogModifiedTime:
    metadataInput?.ogModifiedTime || metadataInput?.dateModified || fallbackIso,
  ogAuthorUrl:
    metadataInput?.ogAuthorUrl || metadataInput?.authorUrl || fallbackAuthorUrl,
  ogTags: Array.isArray(metadataInput?.ogTags) ? metadataInput.ogTags : [],
  twitterTitle: metadataInput?.twitterTitle || paper.title,
  twitterDescription:
    metadataInput?.twitterDescription ||
    metadataInput?.metaDescription ||
    paper.title,
  twitterImage:
    metadataInput?.twitterImage || metadataInput?.ogImage || fallbackImage,
  twitterImageAlt:
    metadataInput?.twitterImageAlt || `Cover image for ${paper.title}`,
  twitterCreator: metadataInput?.twitterCreator || null,
  headline: metadataInput?.headline || paper.title,
  abstract:
    metadataInput?.abstract || metadataInput?.metaDescription || paper.title,
  keywords: metadataInput?.keywords || "",
  articleSection: metadataInput?.articleSection || "General",
  wordCount: metadataInput?.wordCount || 0,
  readingTimeMinutes: metadataInput?.readingTimeMinutes || 1,
  inLanguage: metadataInput?.inLanguage || "en",
  datePublished:
    metadataInput?.datePublished ||
    metadataInput?.ogPublishedTime ||
    fallbackIso,
  dateModified:
    metadataInput?.dateModified || metadataInput?.ogModifiedTime || fallbackIso,
  authorName: metadataInput?.authorName || authorHandle,
  authorHandle: authorHandle,
  authorUrl: metadataInput?.authorUrl || fallbackAuthorUrl,
  authorId: metadataInput?.authorId || "",
  coverImageUrl:
    metadataInput?.coverImageUrl || metadataInput?.ogImage || fallbackImage,
  publisherName: metadataInput?.publisherName || "Whitepapper",
  publisherUrl: metadataInput?.publisherUrl || resolvedSiteUrl,
  isAccessibleForFree:
    typeof metadataInput?.isAccessibleForFree === "boolean"
      ? metadataInput.isAccessibleForFree
      : true,
  license:
    metadataInput?.license || "https://creativecommons.org/licenses/by/4.0/",
};
const ogTags = Array.isArray(metadata.ogTags) ? metadata.ogTags : [];
const readingTimeMinutes = Math.max(1, metadata.readingTimeMinutes || 1);
const authorHref = metadata.authorUrl || `/${authorHandle}`;
const publisherUrl = metadata.publisherUrl || resolvedSiteUrl;
const publisherLogoUrl = `${publisherUrl.replace(/\/+$/, "")}/appLogo.png`;

if (paper.slug !== normalizedSlug) {
  return Astro.redirect(`/${normalizedHandle}/${paper.slug}`, 301);
}

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: metadata.headline,
  description: metadata.metaDescription,
  abstract: metadata.abstract,
  keywords: metadata.keywords,
  articleSection: metadata.articleSection,
  wordCount: metadata.wordCount,
  inLanguage: metadata.inLanguage,
  isAccessibleForFree: metadata.isAccessibleForFree,
  license: metadata.license,
  url: metadata.canonical,
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": metadata.canonical,
  },
  datePublished: metadata.datePublished,
  dateModified: metadata.dateModified,
  author: {
    "@type": "Person",
    name: metadata.authorName,
    url: metadata.authorUrl,
    identifier: metadata.authorId,
  },
  image: {
    "@type": "ImageObject",
    url: metadata.coverImageUrl,
    width: metadata.ogImageWidth,
    height: metadata.ogImageHeight,
  },
  publisher: {
    "@type": "Organization",
    name: metadata.publisherName,
    url: publisherUrl,
    logo: {
      "@type": "ImageObject",
      url: publisherLogoUrl,
      width: 200,
      height: 60,
    },
  },
};

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: metadata.authorName || authorHandle,
      item: authorHref,
    },
    {
      "@type": "ListItem",
      position: 2,
      name: metadata.headline,
      item: metadata.canonical,
    },
  ],
};
---

<Layout title={metadata.title}>
  <Fragment slot="head">
    <meta name="description" content={metadata.metaDescription} />
    <meta name="author" content={metadata.authorName} />
    <meta name="keywords" content={metadata.keywords} />
    <meta name="robots" content={metadata.robots} />
    <link rel="canonical" href={metadata.canonical} />

    <meta property="og:type" content="article" />
    <meta property="og:site_name" content={metadata.publisherName} />
    <meta property="og:title" content={metadata.ogTitle} />
    <meta property="og:description" content={metadata.ogDescription} />
    <meta property="og:url" content={metadata.canonical} />
    <meta property="og:image" content={metadata.ogImage} />
    <meta property="og:image:width" content={String(metadata.ogImageWidth)} />
    <meta property="og:image:height" content={String(metadata.ogImageHeight)} />
    <meta property="og:image:alt" content={metadata.ogImageAlt} />
    <meta property="og:locale" content={metadata.ogLocale} />
    <meta property="og:updated_time" content={metadata.ogModifiedTime} />
    <meta
      property="article:published_time"
      content={metadata.ogPublishedTime}
    />
    <meta property="article:modified_time" content={metadata.ogModifiedTime} />
    <meta property="article:section" content={metadata.articleSection} />
    <meta property="article:author" content={metadata.ogAuthorUrl} />
    {ogTags.map((tag) => <meta property="article:tag" content={tag} />)}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={metadata.canonical} />
    <meta name="twitter:title" content={metadata.twitterTitle} />
    <meta name="twitter:description" content={metadata.twitterDescription} />
    <meta name="twitter:image" content={metadata.twitterImage} />
    <meta name="twitter:image:alt" content={metadata.twitterImageAlt} />
    {
      metadata.twitterCreator ? (
        <meta name="twitter:creator" content={metadata.twitterCreator} />
      ) : null
    }

    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(jsonLd)}
    />
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(breadcrumbJsonLd)}
    />
  </Fragment>

  <main
    class="mx-auto min-h-screen max-w-[700px] px-[15px] pt-[15px] pb-20 md:pt-6"
  >
    <article itemscope itemtype="https://schema.org/Article">
      <header>
        <h1
          itemprop="headline"
          class="text-[28px] md:text-[35px] font-[600] font-[]"
          style={{ lineHeight: "1.4em" }}
        >
          {paper.title}
        </h1>

        <div class="mt-4 flex items-center justify-between gap-3">
          <address class="not-italic">
            <a
              href={authorHref}
              rel="author"
              itemprop="author"
              class="flex items-center gap-[8px] w-fit"
            >
              <p
                class="text-[14px] text-muted-foreground hover:text-foreground transition-all duration-300"
              >
                - {metadata.authorName || authorHandle}
              </p>
            </a>
          </address>

          <div
            class="flex items-center gap-1 text-[14px] text-muted-foreground"
          >
            <time datetime={metadata.dateModified} itemprop="dateModified">
              {updatedDate}
            </time>
            <DotIcon size={20}/>
            <span>{readingTimeMinutes} min read</span>
          </div>
        </div>
      </header>

      {
        paper.thumbnailUrl ? (
          <figure class="mt-6 border rounded-[8px] overflow-hidden">
            <img
              src={paper.thumbnailUrl}
              alt={metadata.ogImageAlt || paper.title}
              itemprop="image"
              class="h-full w-full object-contain"
              loading="eager"
              decoding="async"
              fetchpriority="high"
            />
          </figure>
        ) : null
      }

      <section class="mt-6" aria-label="Article content" itemprop="articleBody">
        <PostPreviewServer content={paper.body} showTOC={true} />
      </section>
    </article>
  </main>
</Layout>

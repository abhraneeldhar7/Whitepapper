---
import Layout from "@/layouts/Layout.astro";
import { getPublicPaperPageData } from "@/lib/api/public";
import { ApiError } from "@/lib/api/client";
import { formatFirestoreDate } from "@/lib/utils";
import PostRender from "@/components/ui/markdown-render/markdown-render";
import { LinesTableOfContent } from "@/components/ui/toc/linesTableOfContent";
import MobileTableOfContent from "@/components/ui/toc/mobileTableOfContent";
import type { PaperDoc } from "@/lib/entities";
import { DotIcon } from "lucide-react";
import { isReservedUsername } from "@/lib/reservedPaths";
import { buildPaperSeoConfig, buildPublicPaperMetadata } from "@/metadata/dynamic";
import { isDesktopUserAgent } from "@/lib/userAgent";

const handle = Astro.params.handle as string;
const pageSlug = Astro.params.slug as string;
const rawHandle = handle.trim();
const normalizedHandle = rawHandle.toLowerCase();
const normalizedSlug = pageSlug.trim().toLowerCase();
const siteUrl = String(import.meta.env.PUBLIC_SITE_URL ?? "")
  .trim()
  .replace(/\/+$/, "");
const userAgent = Astro.request.headers.get("user-agent") ?? "";
const isDesktopUA = isDesktopUserAgent(userAgent);

if (!normalizedHandle || rawHandle.includes("@") || isReservedUsername(normalizedHandle)) {
  return new Response(null, { status: 404 });
}

if (rawHandle !== normalizedHandle || pageSlug !== normalizedSlug) {
  return Astro.redirect(`/${normalizedHandle}/${normalizedSlug}`, 301);
}

Astro.response.headers.set(
  "Cache-Control",
  "public, max-age=300, s-maxage=300, stale-while-revalidate=300",
);
Astro.response.headers.set("Vary", "Accept-Encoding");

let paper: PaperDoc;
try {
  ({ paper } = await getPublicPaperPageData(normalizedHandle, normalizedSlug));
} catch (error) {
  const message = error instanceof Error ? error.message : "";
  if (message.includes("403") || message.includes("Not allowed")) {
    return Astro.redirect("/unauthorized", 302);
  }
  if (error instanceof ApiError && error.status >= 500) {
    return new Response(null, { status: 502 });
  }
  return new Response(null, { status: 404 });
}
const contentContainerId = `post-preview-${paper.paperId || normalizedSlug}`;
const updatedDate = formatFirestoreDate(paper.updatedAt);
const resolvedSiteUrl = siteUrl || Astro.url.origin.replace(/\/+$/, "");
const metadata = buildPublicPaperMetadata({
  paper,
  siteUrl: resolvedSiteUrl,
  handle: normalizedHandle,
});
const readingTimeMinutes = Math.max(1, metadata.readingTimeMinutes || 1);
const authorHandle = metadata.authorHandle || normalizedHandle;
const authorHref = metadata.authorUrl || `/${authorHandle}`;

if (paper.slug !== normalizedSlug) {
  return Astro.redirect(`/${normalizedHandle}/${paper.slug}`, 301);
}

const seo = buildPaperSeoConfig(metadata, {
  schemaType: "Article",
  breadcrumbItems: [
    {
      position: 1,
      name: metadata.authorName || authorHandle,
      item: metadata.authorUrl,
    },
    {
      position: 2,
      name: metadata.headline,
      item: metadata.canonical,
    },
  ],
});
---

<Layout seo={seo} showSiteNav={false}>

  <main
    class="mx-auto min-h-screen max-w-[700px] px-[15px] pt-[15px] pb-20 md:pt-6"
  >
    <article itemscope itemtype="https://schema.org/Article">
      <header>
        <h1
          itemprop="headline"
          class="text-[28px] md:text-[35px] font-[600]"
          style={{ lineHeight: "1.4em" }}
        >
          {paper.title}
        </h1>

        <div class="mt-4 flex items-center justify-between gap-3">
          <address class="not-italic">
            <a
              href={authorHref}
              rel="author"
              itemprop="author"
              class="flex items-center gap-[8px] w-fit"
            >
              <p
                class="text-[14px] text-muted-foreground hover:text-foreground transition-all duration-300"
              >
                - {metadata.authorName || authorHandle}
              </p>
            </a>
          </address>

          <div
            class="flex items-center gap-1 text-[14px] text-muted-foreground"
          >
            <time datetime={metadata.datePublished || metadata.dateModified} itemprop="datePublished">
              {updatedDate}
            </time>
            <DotIcon size={20}/>
            <span>{readingTimeMinutes} min read</span>
          </div>
        </div>
      </header>

      {
        paper.thumbnailUrl ? (
          <figure class="mt-6 border rounded-[8px] overflow-hidden">
            <img
              src={paper.thumbnailUrl}
              alt={metadata.ogImageAlt || paper.title}
              itemprop="image"
              class="h-full w-full object-contain"
              loading="eager"
              decoding="async"
              fetchpriority="high"
            />
          </figure>
        ) : null
      }

      <section class="mt-6" aria-label="Article content" itemprop="articleBody">
        <PostRender content={paper.body || ""} contentContainerId={contentContainerId} />
        {
          isDesktopUA ? (
            <LinesTableOfContent client:load contentContainerId={contentContainerId} />
          ) : (
            <MobileTableOfContent client:load contentContainerId={contentContainerId} />
          )
        }
      </section>
    </article>
  </main>
</Layout>


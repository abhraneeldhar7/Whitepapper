---
import SettingsPage from "@/components/settings/SettingsPage";
import Layout from "@/layouts/Layout.astro";
import { createApiClient } from "@/lib/api/client";
import { getCurrentUser } from "@/lib/api/users";
import type { UserDoc } from "@/lib/types";

const { userId, getToken } = Astro.locals.auth();

if (!userId) {
  return Astro.redirect("/login");
}

const token = await getToken();
if (!token) {
  return Astro.redirect("/login");
}

const serverClient = createApiClient(token);
const initialUser = await getCurrentUser(serverClient).catch(() => null as UserDoc | null);
if (!initialUser) {
  return Astro.redirect("/unauthorized");
}
---

<Layout showSiteNav={false} noindex={true}>
  <SettingsPage client:load initialUser={initialUser} />
</Layout>

---
import DocsPageShell from "@/components/docs/DocsPageShell.astro";
import type { PaperDoc } from "@/lib/entities";
import { buildBlogPaperMetadata, buildPaperSeoConfig } from "@/metadata/dynamic";
import {
  docsNavSections,
  getDocsPageByRoute,
  getDocsPageNeighbors,
  getDocsPaperSlugByRoute,
} from "@/content/docs/docsPagesStructure";
import { fetchDevPaperBySlugRaw } from "@/lib/api/contentFetcher";

const slugParam = Astro.params.slug || "";
const slugValue = Array.isArray(slugParam) ? slugParam.join("/") : slugParam;
if (!slugValue.trim()) {
  return Astro.redirect("/docs/intro", 302);
}

const normalizedSlug = slugValue
  .split("/")
  .filter(Boolean)
  .join("/");
const currentPath = `/docs/${normalizedSlug}`;
const page = getDocsPageByRoute(currentPath);

if (!page) {
  return new Response(null, { status: 404 });
}

const paperSlug = getDocsPaperSlugByRoute(currentPath);
if (!paperSlug) {
  return new Response(null, { status: 404 });
}

const paperResponse = await fetchDevPaperBySlugRaw(paperSlug);
if (!paperResponse.ok) {
  if (paperResponse.status === 404) {
    return new Response(null, { status: 404 });
  }
  const message = await paperResponse.text();
  throw new Error(message || `Upstream request failed with ${paperResponse.status}`);
}

const paperJson = (await paperResponse.json()) as { paper?: PaperDoc };
const paper = paperJson.paper;
if (!paper) {
  return new Response(null, { status: 404 });
}

const markdown = String(paper.body ?? "");
const siteUrl = String(import.meta.env.PUBLIC_SITE_URL ?? "")
  .trim()
  .replace(/\/+$/, "");
const resolvedSiteUrl = siteUrl || Astro.url.origin.replace(/\/+$/, "");

const metadata = buildBlogPaperMetadata({
  paper,
  siteUrl: resolvedSiteUrl,
});

const canonical = `${resolvedSiteUrl}${page.route}`;
const docsMetadata = {
  ...metadata,
  canonical,
};

const docsSeo = buildPaperSeoConfig(docsMetadata, {
  schemaType: "Article",
  breadcrumbItems: [
    {
      position: 1,
      name: "Docs",
      item: `${resolvedSiteUrl}/docs`,
    },
    {
      position: 2,
      name: page.title,
      item: canonical,
    },
  ],
});

const { previous, next } = getDocsPageNeighbors(page.route);
Astro.response.headers.set(
  "Cache-Control",
  "public, max-age=300, s-maxage=300, stale-while-revalidate=300",
);
Astro.response.headers.set(
  "CDN-Cache-Control",
  "public, max-age=300, stale-while-revalidate=300",
);
---

<DocsPageShell
  markdown={markdown}
  currentPath={page.route}
  pageTitle={page.title}
  pageDescription={page.description}
  pageSection={page.sectionTitle}
  seo={docsSeo}
  navSections={docsNavSections}
  previousPage={previous}
  nextPage={next}
/>


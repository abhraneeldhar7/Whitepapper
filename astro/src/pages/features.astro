---
import Layout from "@/layouts/Layout.astro";
import SiteContentListingPage from "@/components/site/SiteContentListingPage.astro";
import { fetchDevCollectionBySlug } from "@/lib/api/contentFetcher";

const features = await fetchDevCollectionBySlug("features");

Astro.response.headers.set(
  "Cache-Control",
  "public, max-age=300, s-maxage=300, stale-while-revalidate=300",
);
---

<Layout>
  <main aria-label="Features listing">
    <SiteContentListingPage
      pageTitle="features"
      primaryTitle="Features"
      backHref="/"
      backLabel="Home"
      primaryPapers={features.papers}
    />
  </main>
</Layout>

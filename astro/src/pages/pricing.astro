---
import Layout from "@/layouts/Layout.astro";
import MarkdownRender from "@/components/ui/markdown-render/markdown-render";
import PricingComparator from "@/components/pricing-comparator";
import FAQs from "@/components/faqs-2";
import { pricingPage } from "@/lib/pricingPage";
import { MAX_CONTENT_PAPER_WIDTH } from "@/lib/design";

const seo = {
  path: "/pricing",
  title: `${pricingPage.title} | Whitepapper`,
  description: pricingPage.description,
  canonical: "/pricing",
  image: "/assets/ogImages/root.png",
  robots: "index, follow",
  ogType: "website",
  ogTitle: `${pricingPage.title} | Whitepapper`,
  ogDescription: pricingPage.description,
  ogUrl: "/pricing",
  ogImage: "/assets/ogImages/root.png",
  ogImageAlt: "Whitepapper pricing cover image",
  twitterCard: "summary_large_image",
  twitterTitle: `${pricingPage.title} | Whitepapper`,
  twitterDescription: pricingPage.description,
  twitterImage: "/assets/ogImages/root.png",
  twitterImageAlt: "Whitepapper pricing cover image",
  jsonLd: [
    {
      "@context": "https://schema.org",
      "@type": "WebPage",
      name: pricingPage.title,
      description: pricingPage.description,
      url: `${Astro.url.origin}/pricing`,
      isPartOf: {
        "@type": "WebSite",
        name: "Whitepapper",
        url: Astro.url.origin,
      },
    },
    ...(pricingPage.faq?.length
      ? [
          {
            "@context": "https://schema.org",
            "@type": "FAQPage",
            mainEntity: pricingPage.faq.map((item) => ({
              "@type": "Question",
              name: item.question,
              acceptedAnswer: {
                "@type": "Answer",
                text: item.answer,
              },
            })),
          },
        ]
      : []),
  ],
};
---

<Layout seo={seo}>
  <main class="w-full px-4 pt-20 md:pt-30">
    <div style={{ maxWidth: `${MAX_CONTENT_PAPER_WIDTH}px` }} class="mx-auto w-full">
      <h1 class="text-[30px] md:text-[40px] font-[400] leading-[1.2em]">
        Whitepapper pricing
      </h1>
      <p class="text-[18px] text-muted-foreground mt-1">
        Lorem ipsum dolor sit amet consectetur adipisicing elit. Aperiam, illum
        sit. Repellat delectus commodi voluptate ea corporis quos numquam quis?
      </p>

      <div class="mt-14">
        <PricingComparator />
      </div>
    </div>
  </main>
</Layout>

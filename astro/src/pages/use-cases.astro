---
import Layout from "@/layouts/Layout.astro";
import SiteContentListingPage from "@/components/site/SiteContentListingPage.astro";
import type { PaperDoc } from "@/lib/entities";

type SiteCollectionResponse = {
  papers: PaperDoc[];
};

const apiBaseUrl = String(import.meta.env.PUBLIC_API_BASE_URL ?? "")
  .trim()
  .replace(/\/+$/, "");
const whitepapperApiKey = String(
  import.meta.env.WHITEPAPPER_API_KEY ?? "",
).trim();

if (!apiBaseUrl || !whitepapperApiKey) {
  throw new Error(
    "PUBLIC_API_BASE_URL and WHITEPAPPER_API_KEY must be configured in Astro env.",
  );
}

const response = await fetch(
  `${apiBaseUrl}/dev/collection?slug=${encodeURIComponent("use-cases")}`,
  {
    method: "GET",
    headers: {
      accept: "application/json",
      "x-api-key": whitepapperApiKey,
    },
  },
);

if (!response.ok) {
  const message = await response.text();
  throw new Error(message || `Upstream request failed with ${response.status}`);
}

const useCases = (await response.json()) as SiteCollectionResponse;

Astro.response.headers.set(
  "Cache-Control",
  "public, max-age=600, s-maxage=600, stale-while-revalidate=600",
);
---

<Layout>
  <main aria-label="Use cases listing">
    <SiteContentListingPage
      pageTitle="use-cases"
      primaryTitle="Use Cases"
      primaryPapers={useCases.papers}
      backHref="/"
      backLabel="Home"
    />
  </main>
</Layout>

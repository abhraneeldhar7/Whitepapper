---
import Layout from "@/layouts/Layout.astro";
import SiteContentListingPage from "@/components/site/SiteContentListingPage.astro";
import { fetchDevCollectionBySlug } from "@/lib/api/contentFetcher";

const useCases = await fetchDevCollectionBySlug("use-cases");

Astro.response.headers.set(
  "Cache-Control",
  "public, max-age=300, s-maxage=300, stale-while-revalidate=300",
);
---

<Layout>
  <main aria-label="Use cases listing">
    <SiteContentListingPage
      pageTitle="use-cases"
      primaryTitle="Use Cases"
      primaryPapers={useCases.papers}
      backHref="/"
      backLabel="Home"
    />
  </main>
</Layout>

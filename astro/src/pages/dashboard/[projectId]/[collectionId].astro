---
import CollectionWorkspace from "@/components/collection/CollectionWorkspace";
import CollectionWorkspaceSkeleton from "@/components/collection/CollectionWorkspaceSkeleton";
import Layout from "@/layouts/Layout.astro";
import { createApiClient } from "@/lib/api/client";
import { getCollection } from "@/lib/api/collections";
import { getProjectById } from "@/lib/api/projects";
import { listProjectPapers } from "@/lib/api/papers";
import { getCurrentUser } from "@/lib/api/users";
import type { CollectionDoc, PaperDoc, UserDoc } from "@/lib/types";
import { isMobileUserAgent } from "@/lib/userAgent";

const { userId, getToken } = Astro.locals.auth();
const projectId = Astro.params.projectId as string;
const collectionId = Astro.params.collectionId as string;

if (!userId) {
  return Astro.redirect("/login");
}

const token = await getToken();
if (!token) {
  return Astro.redirect("/login");
}
const isMobileUA = isMobileUserAgent(Astro.request.headers.get("user-agent"));

const serverClient = createApiClient(token);
const initialUser = await getCurrentUser(serverClient).catch(
  () => null as UserDoc | null,
);

let initialCollection: CollectionDoc;
try {
  initialCollection = await getCollection(collectionId, serverClient);
  if (initialCollection.projectId !== projectId) {
    return Astro.redirect("/404");
  }
} catch (error) {
  const message = error instanceof Error ? error.message : "";
  return Astro.redirect(message.includes("403") || message.includes("Not allowed") ? "/unauthorized" : "/404");
}

const initialPages = await listProjectPapers(projectId, serverClient)
  .then((papers) => papers.filter((p) => p.collectionId === collectionId))
  .catch(() => [] as PaperDoc[]);

const initialProjectName = await getProjectById(projectId, serverClient)
  .then((project) => project.name)
  .catch(() => "Project");
---

<Layout showSiteNav={false}>
  <CollectionWorkspaceSkeleton />
  <div class="collection-shell-app">
    <CollectionWorkspace
      client:only="react"
      projectId={projectId}
      collectionId={collectionId}
      initialProjectName={initialProjectName}
      initialCollection={initialCollection}
      initialPages={initialPages}
      initialUser={initialUser}
      isMobileUA={isMobileUA}
    />
  </div>
</Layout>

---
import BlogListingPage from "@/components/blogs/BlogListingPage.astro";
import Layout from "@/layouts/Layout.astro";
import { getSiteBlogCollectionBySlug } from "@/lib/api/site_blogs";

const updateBlogs = await getSiteBlogCollectionBySlug("updates");


Astro.response.headers.set(
  "Cache-Control",
  "public, max-age=600, s-maxage=600, stale-while-revalidate=600",
);

---

<Layout title="Latest at Whitepapper | Blogs">
    <BlogListingPage
        pageTitle="updates"
        primaryTitle="Updates"
        primaryBlogs={updateBlogs.papers.slice(0, 4)}
        secondaryBlogs={updateBlogs.papers.slice(5, updateBlogs.papers.length)}
    />
</Layout>

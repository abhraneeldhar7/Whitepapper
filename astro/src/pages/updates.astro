---
import BlogListingPage from "@/components/blogs/BlogListingPage.astro";
import Layout from "@/layouts/Layout.astro";
import type { PaperDoc } from "@/lib/types";

type SiteBlogCollectionResponse = {
  papers: PaperDoc[];
};

const apiBaseUrl = String(import.meta.env.PUBLIC_API_BASE_URL ?? "")
  .trim()
  .replace(/\/+$/, "");
const whitepapperApiKey = String(import.meta.env.WHITEPAPPER_API_KEY ?? "").trim();

if (!apiBaseUrl || !whitepapperApiKey) {
  throw new Error("PUBLIC_API_BASE_URL and WHITEPAPPER_API_KEY must be configured in Astro env.");
}

async function fetchSiteBlogCollectionBySlug(slug: string): Promise<SiteBlogCollectionResponse> {
  const response = await fetch(
    `${apiBaseUrl}/dev/collection?slug=${encodeURIComponent(slug)}`,
    {
      method: "GET",
      headers: {
        accept: "application/json",
        "x-api-key": whitepapperApiKey,
      },
    },
  );

  if (!response.ok) {
    const message = await response.text();
    throw new Error(message || `Upstream request failed with ${response.status}`);
  }

  return response.json() as Promise<SiteBlogCollectionResponse>;
}

const updateBlogs = await fetchSiteBlogCollectionBySlug("updates");


Astro.response.headers.set(
  "Cache-Control",
  "public, max-age=600, s-maxage=600, stale-while-revalidate=600",
);

---

<Layout>
  <main aria-label="Updates listing">
    <BlogListingPage
      pageTitle="updates"
      primaryTitle="Updates"
      primaryBlogs={updateBlogs.papers.slice(0, 4)}
      secondaryBlogs={updateBlogs.papers.slice(5, updateBlogs.papers.length)}
    />
  </main>
</Layout>

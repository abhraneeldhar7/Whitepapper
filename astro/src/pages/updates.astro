---
import SiteContentListingPage from "@/components/site/SiteContentListingPage.astro";
import Layout from "@/layouts/Layout.astro";
import { fetchDevCollectionBySlug } from "@/lib/api/contentFetcher";

const updateBlogs = await fetchDevCollectionBySlug("updates");

Astro.response.headers.set(
  "Cache-Control",
  "public, max-age=300, s-maxage=300, stale-while-revalidate=300",
);
---

<Layout>
  <main aria-label="Updates listing">
    <SiteContentListingPage
      pageTitle="updates"
      primaryTitle="Updates"
      backHref="/blogs"
      backLabel="Blogs"
      primaryBlogs={updateBlogs.papers.slice(0, 4)}
      secondaryBlogs={updateBlogs.papers.slice(5, updateBlogs.papers.length)}
    />
  </main>
</Layout>

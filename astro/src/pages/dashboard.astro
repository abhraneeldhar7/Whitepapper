---
import Layout from "@/layouts/Layout.astro";
import DashboardApp from "@/components/dashboard/DashboardApp";
import DashboardSkeleton from "@/components/dashboard/DashboardSkeleton";
import { createApiClient } from "@/lib/api/client";
import { getDashboardData } from "@/lib/api/users";
import { isMobileUserAgent } from "@/lib/userAgent";

const { userId, getToken } = Astro.locals.auth();

const token = await getToken();
const isMobileUA = isMobileUserAgent(Astro.request.headers.get("user-agent"));

const serverClient = createApiClient(token);
const dashboardData = await getDashboardData(serverClient).catch(() => null);

if (!dashboardData) {
  return Astro.redirect("/login");
}

const { user: initialUser, projects: initialProjects, papers: initialPages } = dashboardData;
---

<Layout showSiteNav={false}>
  <DashboardApp
    client:only="react"
    initialProjects={initialProjects}
    initialPages={initialPages}
    initialUser={initialUser}
    isMobileUA={isMobileUA}
  >
    <DashboardSkeleton slot="fallback" />
  </DashboardApp>
</Layout>

						src="/appLogo.png"
						class="object-contain h-[14px] w-[14px] md:h-[20px] md:w-[20px] z-[2] absolute top-[20%] right-[30%]"
					/>
					<img
						src="/appLogo.png"
						class="object-contain h-[14px] w-[14px] md:h-[20px] md:w-[20px] z-[2] absolute top-[45%] right-[28%]"

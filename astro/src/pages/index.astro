---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";

import HeroDashboardLight from "@/assets/landingPage/hero_light.png";
import MetatagsEditorLight from "@/assets/landingPage/metatags_editor_light.png";
import BlueBgPattern from "@/assets/landingPage/blueBgPattern.jpg";
import LandingArticleList from "@/components/landing/LandingArticleList.astro";

import IntegrationsSection from "@/components/integrations-4";
import FAQs from "@/components/faqs-2";

import BlogsPageImg from "@/assets/landingPage/blogsPage.png";
import TweetStack from "@/components/tweetCards";

const featuredArticles = [
	{
		title: "How to Write Content That AI Assistants Actually Quote",
		readTime: "6 min read",
		href: "/abhraneeldhar7/paper-20491f39-fcff-4683-9c01-d856dab87b9f",
	},
	{
		title: "How to Make Your Brand Recognizable to AI Systems",
		readTime: "1 min read",
		href: "/abhraneeldhar7/paper-5846b146-e7a0-424f-8eff-2818b695fe1e",
	},
];

const homeFaqs = [
	{
		question: "What is Whitepapper?",
		answer: "Whitepapper is a markdown-first content platform for developers who want one source of truth for public pages, docs, blog posts, and API-backed content reuse.",
	},
	{
		question: "Who is Whitepapper for?",
		answer: "Whitepapper is built for solo developers, indie builders, technical writers, and small teams who want a practical publishing workflow without a bloated CMS.",
	},
	{
		question: "How does Whitepapper help SEO and AI visibility?",
		answer: "Whitepapper keeps metadata, canonical rules, public pages, schema, sitemaps, and LLM-facing files close to the content so search engines and AI systems can understand the same page clearly.",
	},
];

const homeExploreLinks = [
	{
		href: "/features",
		title: "Features",
		description:
			"See the core product pages for the Content API, distribution flow, metadata workflow, and public pages.",
	},
	{
		href: "/use-cases",
		title: "Use Cases",
		description:
			"Explore how Whitepapper fits developer blogs, portfolio frontends, and docs-plus-updates workflows.",
	},
	{
		href: "/pricing",
		title: "Pricing",
		description:
			"Review the current free plan and the machine-readable pricing file published for AI agents.",
	},
	{
		href: "/compare/whitepapper-vs-ghost",
		title: "Compare",
		description:
			"Compare Whitepapper with Ghost, Hashnode, and a Dev.to-only workflow without leaving the site.",
	},
	{
		href: "/glossary/llms-txt",
		title: "Glossary",
		description:
			"Read plain-English definitions for llms.txt, canonical URLs, content APIs, and programmatic SEO.",
	},
];

import { MAX_LANDING_PAGE_WIDTH } from "@/lib/design";
import {
	BookMarkedIcon,
	BotIcon,
	GithubIcon,
	SearchCheckIcon,
	SquareMIcon,
	UnplugIcon,
	WorkflowIcon,
	ZapIcon,
} from "lucide-react";

Astro.response.headers.set(
	"Cache-Control",
	"public, max-age=600, s-maxage=3600, stale-while-revalidate=86400",
);

const featuresDivs = [
	{
		icon: ZapIcon,
		title: "Fast",
		description:
			"Cached at edge using Cloudflare CDN for global fast access.",
	},
	{
		icon: WorkflowIcon,
		title: "Distribution",
		description:
			"One-click distribution to Dev.to, Hashnode, and Medium, Linkedin",
	},
	{
		icon: SearchCheckIcon,
		title: "SEO",
		description:
			"Automated SEO emtatags and JSON-LD generation for every paper.",
	},
	{
		icon: UnplugIcon,
		title: "Content API",
		description: "Zero configuration API to power your websites",
	},
	{
		icon: SquareMIcon,
		title: "WYSIWYG Editor",
		description: "Rich markdown editor with in-built SEO handling.",
	},
	{
		icon: BotIcon,
		title: "MCP ready",
		description: "Make your agents write SEO rich structured content.",
	},
	{
		icon: GithubIcon,
		title: "Open Source",
		description: "Fully open source on GitHub with a self hosting guide",
	},
	{
		icon: BookMarkedIcon,
		title: "Learn",
		description:
			"Read how whitepapper pushes your content above other platforms",
	},
];

import worldmapDots from "@/assets/landingPage/worldmapDots.png";
import {ApiShowcase} from "@/components/apiShowcase.tsx";
---

<Layout reserveNavSpace={false}>
		<main class="relative mb-20" aria-label="Whitepapper home">
			
			<section
			class="relative flex flex-col items-start justify-start pt-40 md:pt-50 h-full overflow-hidden px-5 md:px-15"
			aria-labelledby="home-hero-title"
			>
			<div
			class="pb-[50px] mx-auto w-full"
			style={{ maxWidth: `${MAX_LANDING_PAGE_WIDTH}px` }}
			>
			
			<div class="mx-auto w-full"></div>
			<div
				class="absolute left-[-80%] top-[3%] z-[-1] h-[10px] w-[700px] md:w-[1200px] rotate-[40deg] rounded-[50%] bg-foreground blur-[40px] dark:blur-[45px] md:left-[-30%] md:top-[-2%]"
				aria-hidden="true"
			>
			</div>
			<div
				class="absolute left-[-45%] top-[0%] z-[-1] h-[8px] w-[700px] md:w-[1200px] rotate-[40deg] rounded-[50%] bg-foreground blur-[40px] dark:blur-[45px] md:left-[-50%] md:top-[-3%]"
				aria-hidden="true"
			>
			</div>
				<h1
					id="home-hero-title"
					class="heroText text-[30px] md:text-[45px] flex md:flex-row flex-col md:gap-4 font-[500]"
				>
					Most powerful <br />Content managemenent system
				</h1>

				<div class="my-4 space-y-2 text-muted-foreground md:w-[700px]">
					<p class="heroText" style="animation-delay: 0.25s;"></p>
				</div>

				<div
					class="heroText mt-8 relative p-3 md:p-10 overflow-hidden md:rounded-[30px] rounded-[20px] h-full border shadow-md"
					style="animation-delay: 0.3s; animation-duration: 0.8s;"
				>
					<Image
						src={BlueBgPattern}
						alt="Green pattern background"
						class="absolute left-0 top-0 z-[-1] h-full w-full"
						loading="eager"
						quality={60}
					/>
					<Image
						src={HeroDashboardLight}
						alt="Whitepapper dashboard preview"
						class="h-fit w-full rounded-[10px]"
						loading="eager"
						fetchpriority="high"
					/>
				</div>
			</div>

			<div
				class="heroText absolute bottom-[5%] md:bottom-[25%] left-[50%] z-[-1] h-[110vw] w-[200vw] translate-x-[-50%] translate-y-[54%] overflow-hidden rounded-[50%] md:w-[150vw] md:translate-y-[85%] ease-in"
				style="animation-delay: 0.5s;"
			>
				<div
					class="h-[110vw] w-full rounded-[50%] border-[5px] border-foreground/80 blur-[20px]"
					aria-hidden="true"
				>
				</div>
			</div>
		</section>

		<div class="px-5 md:px-15">
			<div
				class="md:mt-12 md:mb-27 mt-4 mb-17 grid grid-cols-2 md:flex w-full mx-auto gap-3 md:justify-between"
				style={{ maxWidth: `${MAX_LANDING_PAGE_WIDTH}px` }}
			>
				{
					featuresDivs.slice(0, 4).map((item) => (
						<div class="flex flex-col flex-1 gap-2 p-3 transition-all duration-300 hover:bg-card">
							<div class="flex items-center gap-3">
								<item.icon size={19} />
								<h2 class="text-[17px] font-[450]">
									{item.title}
								</h2>
							</div>
							<p class="text-sm text-foreground">
								{item.description}
							</p>
						</div>
					))
				}
			</div>
		</div>

		<!-- <TweetStack client:idle/> -->

		<section
			class="mx-auto flex w-full flex-col px-5 md:px-15"
			aria-label="Product highlights"
		>
			<div
				style={{ maxWidth: `${MAX_LANDING_PAGE_WIDTH}px` }}
				class="flex w-full mx-auto flex-col-reverse gap-6 md:flex-row md:items-start md:gap-20"
			>
				<div class="flex-1">
					<div
						class="relative h-full w-full overflow-hidden rounded-[18px] md:rounded-[36px] p-3 md:p-8"
					>
						<Image
							src={BlueBgPattern}
							alt="Green pattern background"
							class="absolute left-0 top-0 z-[-1] h-full w-full"
							loading="lazy"
							quality={70}
							decoding="async"
						/>
						<Image
							src={MetatagsEditorLight}
							alt="Editor preview"
							class="h-full w-full object-cover rounded-[8px] md:rounded-[12px]"
							loading="lazy"
							decoding="async"
						/>
					</div>

					<LandingArticleList
						items={featuredArticles}
						className="md:hidden mt-10"
					/>
				</div>

				<div class="md:flex-1">
					<div>
						<h2 class="text-[32px] font-[500]">
							Automated SEO tags
						</h2>

						<p class="mt-2 text-muted-foreground">
							Every paper you publish on Whitepapper gets their
							metatags, JSON-LD and open graph image
							automatically. No manual hassle, no copy-pasting.<br
							/> Your content is SEO ready the moment you hit publish.
						</p>
					</div>
					<LandingArticleList
						items={featuredArticles}
						className="mt-65 hidden md:block"
					/>
				</div>
			</div>

			<div
				class="w-full mx-auto mt-18 md:mt-40"
				style={{ maxWidth: `${MAX_LANDING_PAGE_WIDTH}px` }}
			>
				<h2 class="text-[32px] font-[500]">Fast worldwide</h2>
				<p class="mt-1 text-muted-foreground">
					Whitepapper is cached at edge using <span
						class="text-[#F48120] px-[2px]">cloudflare</span
					> CDN to reach users at
					<span class="font-[450] text-foreground">~ 100ms</span><br
					/>
					No confirugations needed.
				</p>

				<div class="relative mt-5">
					<img
						src="/appLogo.png"
						class="object-contain h-[14px] w-[14px] md:h-[20px] md:w-[20px] z-[2] absolute top-[6%] left-[10%]"
					/>
					<img
						src="/appLogo.png"
						class="object-contain h-[14px] w-[14px] md:h-[20px] md:w-[20px] z-[2] absolute top-[32%] left-[25%]"
					/>
					<img
						src="/appLogo.png"
						class="object-contain h-[14px] w-[14px] md:h-[20px] md:w-[20px] z-[2] absolute top-[12%] right-[14%]"
					/>
					<img
						src="/appLogo.png"
						class="object-contain h-[14px] w-[14px] md:h-[20px] md:w-[20px] z-[2] absolute top-[20%] right-[30%]"
					/>
					<img
						src="/appLogo.png"
						class="object-contain h-[14px] w-[14px] md:h-[20px] md:w-[20px] z-[2] absolute top-[45%] right-[28%]"
					/>
					<img
						src={worldmapDots.src}
						class="w-full h-full object-contain invert dark:invert-0"
					/>
					<div
						class="bg-gradient-to-t md:h-[50%] h-full w-full absolute bottom-0 left-0 from-background from-20% md:from-40% to-transparent to-100% z-3"
					>
					</div>
				</div>
			</div>

			<div class="w-full mx-auto mt-20 md:mt-40 px-5 md:px-15 flex md:flex-row flex-col md:justify-between gap-10" style={{ maxWidth: `${MAX_LANDING_PAGE_WIDTH}px` }}>
									<div class="flex-1 shrink-0">
					
					<IntegrationsSection />
				</div>
				<div class="flex-1 shrink-0">

					<ApiShowcase client:idle/>
				</div>
			</div>

			<div class="mt-20 md:mt-40 px5- md:px-15">

				<div style={{ maxWidth: `${MAX_LANDING_PAGE_WIDTH}px` }}>
					<div
					class="flex md:flex-row flex-col gap-3 justify-between items-start"
					>
					<h2 class="md:flex-1 text-[30px] md:text-[40px] font-[450]">
						Make your sites searchable
					</h2>
					<p class="md:flex-1 text-muted-foreground md:text-[20px]">
						Every project gets a scoped API key. Use it to pull your
						papers, collections, and project data directly into your
						portfolio, personal site, or any frontend you're
						building. Read-only, fast, and safe to expose publicly.
					</p>
				</div>
				<div
				class="mt-8 md:mt-15 relative p-3 md:p-15 overflow-hidden md:rounded-[30px] rounded-[20px] h-full border shadow-md"
				>
				<Image
				src={BlueBgPattern}
				alt="Green pattern background"
				class="absolute left-0 top-0 z-[-1] h-full w-full"
				loading="lazy"
				quality={70}
				decoding="async"
				/>
				<Image
				src={BlogsPageImg}
				alt="Blogs page preview"
				class="h-fit w-full rounded-[10px]"
				loading="lazy"
				decoding="async"
				/>
			</div>
			<a href="/docs" class="w-fit">
				<p class="text-sm text-muted-foreground my-4 text-center">
					Read the API docs
				</p>
			</a>
		</div>
	</div>





			<section class="space-y-4">
				<FAQs
					client:idle
					items={homeFaqs}
					title="FAQ"
					description="A quick overview of what Whitepapper is, who it serves, and why the public page layer matters."
				/>
			</section>
		</section>
	</main>
</Layout>

<style>
	.heroText {
		animation: fadeInUp 0.5s ease-out forwards;
		animation-fill-mode: both;
	}

	@keyframes fadeInUp {
		from {
			opacity: 0;
			transform: translateY(30px);
		}
		
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}
</style>

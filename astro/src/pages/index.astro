---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";

import HeroDashboardLight from "@/assets/landingPage/hero_light.png";
import BlueBgPattern from "@/assets/landingPage/blueBgPattern.jpg";
import FAQs from "@/components/faqs-2";

const homeFaqs = [
	{
		question: "What is Whitepapper?",
		answer: "Whitepapper is a markdown-first content platform for developers who want one source of truth for public pages, docs, blog posts, and API-backed content reuse.",
	},
	{
		question: "Who is Whitepapper for?",
		answer: "Whitepapper is built for solo developers, indie builders, technical writers, and small teams who want a practical publishing workflow without a bloated CMS.",
	},
	{
		question: "How does Whitepapper help SEO and AI visibility?",
		answer: "Whitepapper keeps metadata, canonical rules, public pages, schema, sitemaps, and LLM-facing files close to the content so search engines and AI systems can understand the same page clearly.",
	},
];

import { MAX_LANDING_PAGE_WIDTH } from "@/lib/design";
import {
	ArrowRight,
	BookMarkedIcon,
	BookmarkIcon,
	BotIcon,
	FolderIcon,
	GithubIcon,
	PaperclipIcon,
	ScrollTextIcon,
	SearchCheckIcon,
	SendIcon,
	SquareMIcon,
	UnplugIcon,
	WorkflowIcon,
	ZapIcon,
} from "lucide-react";

Astro.response.headers.set(
	"Cache-Control",
	"public, max-age=600, s-maxage=3600, stale-while-revalidate=86400",
);

const featuresDivs = [
	{
		icon: ZapIcon,
		title: "Fast",
		description:
			"Cached at edge using Cloudflare CDN for global fast access.",
	},
	{
		icon: WorkflowIcon,
		title: "Distribution",
		description:
			"One-click distribution to Dev.to, Hashnode, and Medium, Linkedin",
	},
	{
		icon: SearchCheckIcon,
		title: "SEO",
		description:
			"Automated SEO emtatags and JSON-LD generation for every paper.",
	},
	{
		icon: UnplugIcon,
		title: "Content API",
		description: "Zero configuration API to power your websites",
	},
	{
		icon: SquareMIcon,
		title: "WYSIWYG Editor",
		description: "Rich markdown editor with in-built SEO handling.",
	},
	{
		icon: BotIcon,
		title: "MCP ready",
		description: "Make your agents write SEO rich structured content.",
	},
	{
		icon: GithubIcon,
		title: "Open Source",
		description: "Fully open source on GitHub with a self hosting guide",
	},
	{
		icon: BookMarkedIcon,
		title: "Learn",
		description:
			"Read how whitepapper pushes your content above other platforms",
	},
];

import HeroFloatingIcon from "@/components/landing/heroFloatingIcons.astro";

import worldmapDots from "@/assets/landingPage/worldmapDots.png";
import npmLogo from "@/assets/logos/npm-logo.svg";
import MorphingText from "@/components/ui/morphing-text";
import { Button } from "@/components/ui/button";
import Integrations4 from "@/components/integrations-4.astro";
import { ApiShowcase } from "@/components/apiShowcase";

import vscode_mcp from "@/assets/landingPage/vscode_mcp.png";
import chatgpt_mobile from "@/assets/landingPage/chatgpt_mobile.jpeg";
---

<Layout reserveNavSpace={false}>
	<main
		class="relative font-[Satoshi] font-[420]"
		aria-label="Whitepapper home"
	>
		<section
			class="relative flex flex-col w-full h-full overflow-hidden px-5 md:px-15"
			aria-labelledby="home-hero-title"
		>
			<div
				class="pt-45 pb-20 md:pb-30 relative mx-auto w-full"
				style={{ maxWidth: `${MAX_LANDING_PAGE_WIDTH}px` }}
			>
				<HeroFloatingIcon
					Icon={PaperclipIcon}
					style={{ animationDelay: "0.2s" }}
					className="bg-[#21d2f7]/10 text-[#21d2f7] absolute top-[6%] md:top-[5%] left-[10%] md:left-[7%] rotate-[-12deg]"
				/>
				<HeroFloatingIcon
					Icon={SendIcon}
					style={{ animationDelay: "0.5s" }}
					className="bg-[#f72523]/15 text-[#f72523] absolute top-[30%] md:top-[20%] left-[-12%] md:left-[-4%] rotate-[15deg]"
				/>
				<HeroFloatingIcon
					Icon={ScrollTextIcon}
					style={{ animationDelay: "0.9s" }}
					className="bg-[#21f79c]/10 text-[#21f79c] absolute top-[50%] md:top-[32%] left-[3%] md:left-[14%] rotate-[-6deg]"
				/>
				<HeroFloatingIcon
					Icon={WorkflowIcon}
					style={{ animationDelay: "0.4s" }}
					className="bg-[#fc4fb0]/10 text-[#fc4fb0] absolute top-[10%] md:top-[6%] right-[4%] md:right-[15%] rotate-[16deg]"
				/>
				<HeroFloatingIcon
					Icon={UnplugIcon}
					style={{ animationDelay: "0.8s" }}
					className="bg-[#9223f7]/10 text-[#9223f7] absolute top-[25%] md:top-[18%] right-[-12%] md:right-[-1%] rotate-[8deg]"
				/>
				<HeroFloatingIcon
					Icon={FolderIcon}
					style={{ animationDelay: "0.12s" }}
					className="bg-[#f79123]/10 text-[#f79123] absolute top-[46%] md:top-[30%] right-[7%] md:right-[16%] rotate-[-5deg]"
				/>

				<div class="flex flex-col w-full items-center">
					<h1
						class="heroText text-center text-[50px] md:text-[85px] font-[600]"
					>
						Ship content.
					</h1>

					<div
						class="heroText mt-2 text-center text-muted-foreground leading-[1.6em] text-[20px] md:text-[22px] max-w-[500px]"
						style="animation-delay: 0.2s;"
					>
						<span>
							The CMS that handles publishing, SEO, and
							distribution
						</span>
						<span>for your</span>
						<span class="hidden"
							>websites, projects, business, blogs, docs</span
						>
						<MorphingText
							client:load
							texts={[
								"websites",
								"projects",
								"business",
								"blogs",
								"docs",
							]}
						/>
					</div>

					<div class="heroText my-10" style="animation-delay: 0.5s;">
						<Button size="lg">Start publishing</Button>
					</div>
				</div>

				<div
					class="heroText mt-2 md:mt-4 relative p-4 md:p-14 overflow-hidden md:rounded-[30px] rounded-[20px] h-full"
					style="animation-delay: 0.4s;"
				>
					<Image
						src={BlueBgPattern}
						alt="Green pattern background"
						class="absolute object-cover left-0 top-0 z-[-1] h-full w-full"
						loading="eager"
						quality={60}
					/>
					<Image
						src={HeroDashboardLight}
						alt="Whitepapper dashboard preview"
						class="h-full rounded-[10px] w-full"
						loading="eager"
						fetchpriority="high"
					/>
				</div>
			</div>

			<div
				class="heroText absolute bottom-[5%] md:bottom-[25%] left-[50%] z-[-1] h-[110vw] w-[200vw] translate-x-[-50%] translate-y-[54%] overflow-hidden rounded-[50%] md:w-[150vw] md:translate-y-[85%] ease-in"
				style="animation-delay: 0.5s;"
			>
				<div
					class="h-[110vw] w-full rounded-[50%] border-[5px] border-foreground/80 blur-[20px]"
					aria-hidden="true"
				>
				</div>
			</div>
		</section>

		<!-- <div
			class="w-full text-[15px] text-center bg-foreground text-background px-4 py-3 sticky top-[50px] z-[5]"

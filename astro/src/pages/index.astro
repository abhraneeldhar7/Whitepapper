					>
					</div>
				</div>
			</div>
		</section>

		<section class="mt-15 md:mt-25 px-5 md:px-15" aria-label="MCP server">
			<div
				class="w-full mx-auto"
				style={{ maxWidth: `${MAX_LANDING_PAGE_WIDTH}px` }}
			>
				<div
					class="gap-7 md:gap-15 w-full relative overflow-hidden grid md:grid-cols-2 grid-cols-1"
				>
					<div class="md:flex-1 flex flex-col h-full">
						<h2 class="text-[34px] md:text-[40px] font-[500]">
							Whitepapper MCP
						</h2>
						<p
							class="mt-1 md:text-[19px] text-muted-foreground max-w-[400px]"
						>
							Connect whitepapper to agents and automate content
							writing for your projects
						</p>

						<div
							class="mt-10 relative overflow-hidden w-full h-[260px] md:h-full"
						>
							<div
								class="bg-gradient-to-b h-[120px] w-full absolute top-[-1px] left-0 from-background from-0% to-transparent to-100% z-3"
							>
							</div>
							<div
								class="border-[3px] border-[#fafafa]/30 border-t-0 rounded-b-[50px] overflow-hidden px-[10px] pb-[30px] bg-[#050505] h-full"

---
import Layout from "../layouts/Layout.astro";
import LandingMobileMenu from "@/components/landing/LandingMobileMenu";
import { ArrowUpRight } from "lucide-react";

import LinkedinLogo from "@/assets/logos/linkedinLogo.png";
import PeerlistLogo from "@/assets/logos/peerList.webp";
import XLogo from "@/assets/logos/xLogo.jpg";
import MediumLogo from "@/assets/logos/mediumLogo.jpeg";
import RedditLogo from "@/assets/logos/redditLogo.jpeg";
import DevtoLogo from "@/assets/logos/devto.webp";
import HashnodeLogo from "@/assets/logos/hashnodeLogo.png";
import SubstackLogo from "@/assets/logos/substackLogo.png";
import ThreadsLogo from "@/assets/logos/threadsLogo.png";

import { Button } from "@/components/ui/button";

import HeroDashboardLight from "@/assets/landingPage/hero_light.png";
import MetatagsEditorLight from "@/assets/landingPage/metatags_editor_light.png";
import BlueBgPattern from "@/assets/landingPage/blueBgPattern.jpg";

const integrationLogoList = [
	{ src: LinkedinLogo, alt: "LinkedIn" },
	{ src: MediumLogo, alt: "Medium" },
	{ src: XLogo, alt: "X" },
	{ src: PeerlistLogo, alt: "Peerlist" },
	{ src: RedditLogo, alt: "Reddit" },
	{ src: DevtoLogo, alt: "Dev.to" },
	{ src: HashnodeLogo, alt: "Hashnode" },
	{ src: SubstackLogo, alt: "Substack" },
	{ src: ThreadsLogo, alt: "Threads" },
];

const navButtonsList = [
	{ title: "Docs", href: "/docs" },
	{ title: "Integrations", href: "/int" },
	{ title: "Blog", href: "/blog" },
	{ title: "Components", href: "/components" },
	{ title: "Pricing", href: "/pricing" },
];

import TeslaLogo from "@/assets/logos/bullshi/tesla_logo.png";
import AudiLogo from "@/assets/logos/bullshi/audi_logo.png";
import GoogleLogo from "@/assets/logos/bullshi/google_logo.webp";
import OpenAILogo from "@/assets/logos/bullshi/openai_logo.png";
import CursorLogo from "@/assets/logos/bullshi/cursor_logo.png";

Astro.response.headers.set(
	"Cache-Control",
	"public, max-age=600, s-maxage=600, stale-while-revalidate=600",
);
---

<Layout>
	<div class="relative mb-20 overflow-hidden">
		<div
			class="fixed left-0 top-0 z-[10] flex w-full items-center justify-center gap-5 px-4 py-2 backdrop-blur-[20px] bg-background/80 border-b border-border/50"
		>
			<div
				class="max-w-[1200px] w-full flex items-center justify-between gap-10"
			>
				<div>
					<img
						src="/appLogo.png"
						height="30"
						width="30"
						class="md:hidden"
					/>
				</div>

				<div class="hidden gap-5 text-[14px] leading-[1em] md:flex">
					{
						navButtonsList.map((button) => (
							<a
								href={button.href}
								class="group flex cursor-pointer gap-2 p-3 dark:font-[350] font-[400] opacity-[0.8] transition-all duration-300 hover:opacity-[1]"
							>
								{button.title}
								<ArrowUpRight className="size-[14px] opacity-[0.7] transition-all duration-300 group-hover:opacity-[1]" />
							</a>
						))
					}
				</div>

				<div class="flex gap-4">
					<a href="/sign-up">
						<Button className="w-[80px]"> Login </Button>
					</a>

					<div class="md:hidden">
						<LandingMobileMenu
							client:load
							navButtons={navButtonsList}
						/>
					</div>
				</div>
			</div>
		</div>

		<div class="mx-auto w-full max-w-[1600px] px-5 md:px-15">
			<div
				class="absolute left-[-80%] top-[3%] z-[-1] h-[10px] w-[700px] md:w-[1200px] rotate-[40deg] rounded-[50%] bg-foreground blur-[40px] dark:blur-[45px] md:left-[-30%] md:top-[-2%]"
			>
			</div>
			<div
				class="absolute left-[-45%] top-[0%] z-[-1] h-[8px] w-[700px] md:w-[1200px] rotate-[40deg] rounded-[50%] bg-foreground blur-[40px] dark:blur-[45px] md:left-[-50%] md:top-[-3%]"
			>
			</div>

			<div
				class="relative flex flex-col items-start justify-start pt-28 md:pt-30"
			>
				<h1
					class="heroText text-[50px] md:text-[60px] flex md:flex-row flex-col md:gap-4 font-[450]"
				>
					<span>SEO first</span><span> content engine</span>
				</h1>

				<p
					class="heroText text-[17px] text-muted-foreground my-4 md:w-[600px]"
					style="animation-delay: 0.25s;"
				>
					Lorem ipsum dolor, sit amet consectetur adipisicing elit.
					Quibusdam, dolore quam consectetur quisquam officiis
					voluptatem!
				</p>

				<!-- <div class="flex gap-2 items-center justify-center w-full mt-5">
					<p class="text-[12px]">Not backed by</p>
					<div
						class="bg-[#fb6518] text-[white] text-[11px] font-[400] leading-[12px] w-[20px] h-[20px] flex items-center justify-center"
					>
						Y
					</div>
				</div> -->

				
				<div
					class="heroText mt-8 md:mt-15 relative p-3 md:p-10 overflow-hidden md:rounded-[30px] rounded-[20px] h-full border shadow-md"
					style="animation-delay: 0.3s; animation-duration: 0.8s;"
				>
					<img
						src={BlueBgPattern.src}
						alt="Green pattern background"
						class="absolute left-0 top-0 z-[-1] h-full w-full"
						loading="lazy"
						decoding="async"
					/>
					<img
						src={HeroDashboardLight.src}
						alt=""
						class="h-fit w-full rounded-[10px] border"
					/>
				</div>

				<div
					class="heroText absolute bottom-0 left-[50%] z-[-1] h-[110vw] w-[200vw] translate-x-[-50%] translate-y-[54%] overflow-hidden rounded-[50%] md:w-[150vw] md:translate-y-[85%] ease-in"
					style="animation-delay: 0.5s;"
				>
					<div
						class="h-[110vw] w-full rounded-[50%] border-[5px] border-foreground/50 blur-[20px]"
					>
					</div>
				</div>
			</div>

			<p class="text-center text-[15px] my-10">
				Whitepapper is <a
					href="https://github.com/abhraneeldhar7/Whitepapper"
					target="_blank"
					class="font-[450] underline">open-sourced</a
				> for schizo writers
			</p>

			<!-- <div
				class="my-15 md:my-20 flex flex-col items-center md:gap-7 gap-5"
			>
				<h2 class="text-[20px]">Look at these logos lmfao</h2>
				<div
					class="flex gap-x-7 gap-y-5 grayscale opacity-[0.5] flex-wrap justify-center items-center"
				>
					<img src={OpenAILogo.src} class="h-[30px] w-fit" />
					<img src={GoogleLogo.src} class="h-[30px] w-fit" />
					<img src={AudiLogo.src} class="h-[30px] w-fit" />
					<img src={CursorLogo.src} class="h-[30px] w-fit" />
					<img src={TeslaLogo.src} class="h-[30px] w-fit" />
				</div>
			</div> -->

			<div class="mx-auto flex w-full flex-col gap-15 md:gap-40">
				<div
					class="flex w-full flex-col-reverse gap-6 md:flex-row md:items-end md:gap-20"
				>
					<div
						class="relative flex-1 overflow-hidden rounded-[18px] md:rounded-[30px] p-3 md:p-8"
					>
						<img
							src={BlueBgPattern.src}
							alt="Green pattern background"
							class="absolute left-0 top-0 z-[-1] h-full w-full"
							loading="lazy"
							decoding="async"
						/>
						<img
							src={MetatagsEditorLight.src}
							alt="Editor preview"
							class="h-full w-full object-cover rounded-[8px] md:rounded-[15px]"
							loading="lazy"
							decoding="async"
						/>
					</div>

					<div class="md:flex-1">
						<h1 class="text-[30px] font-[450]">
							Auto generated metatags for better SEO
						</h1>
						<p class="mt-1 text-[16px] font-[350]">
							Lorem ipsum dolor sit amet consectetur adipisicing
							elit. Ex, earum. Nostrum, nihil sapiente sint
							tempore quam expedita et id in officia eos
							consequuntur esse repudiandae perspiciatis explicabo
							unde nesciunt quo!
						</p>
					</div>
				</div>
			</div>
		</div>
	</div>
</Layout>

<style>
	.heroText {
		animation: fadeInUp 0.5s ease-out forwards;
		animation-fill-mode: both;
	}

	@keyframes fadeInUp {
		from {
			opacity: 0;
			transform: translateY(30px);
		}

		to {
			opacity: 1;
			transform: translateY(0);
		}
	}
</style>

								ex.
							</h3>
							<p class="text-[15px] text-muted-foreground mt-2">
								Lorem ipsum dolor sit, amet consectetur
								adipisicing elit. Tempore omnis veritatis ipsum
								maiores.
							</p>
						</div>
					</div>
					<div
						class="flex md:flex-row flex-col-reverse gap-4 md:gap-10 border-b pb-5"
					>
						<p class="w-[200px] font-[500] text-[15px] md:pt-1">
							4 min read
						</p>
						<div>
							<h3 class="text-[20px]">
								Lorem, ipsum dolor adipisicing elit. Aliquam,
								ex.
							</h3>
							<p class="text-[15px] text-muted-foreground mt-2">
								Lorem ipsum dolor sit, amet consectetur
								adipisicing elit. Tempore omnis veritatis ipsum
								maiores.
							</p>
						</div>
					</div>
					<div
						class="flex md:flex-row flex-col-reverse gap-4 md:gap-10"
					>
						<p class="w-[200px] font-[500] text-[15px] md:pt-1">
							4 min read
						</p>
						<div>
							<h3 class="text-[20px]">
								Lorem, ipsum dolor adipisicing elit. Aliquam,
								ex.
							</h3>
							<p class="text-[15px] text-muted-foreground mt-2">
								Lorem ipsum dolor sit, amet consectetur
								adipisicing elit. Tempore omnis veritatis ipsum
								maiores.
							</p>
						</div>
					</div>
				</div>
			</div>
		</section>

		<section class="px-5 md:px-15 mt-30 md:mt-60">
			<div
				class="w-full mx-auto flex md:flex-row flex-col gap-7 md:gap-20"
				style={{ maxWidth: `${MAX_LANDING_PAGE_WIDTH}px` }}
			>
				<div class="md:flex-1 shrink-0">
					<h2 class="text-[34px] md:text-[40px] font-[500]">
						Integrate your websites with Dev API
					</h2>
					<div class="md:text-[19px] mt-4">
						<p class="leading-[2.1em] mt-4">
							Whitepapper

							<a
								ata-astro-prefetch="viewport"
								href="/docs"
								class="px-2 py-1 text-[17px] shadow-sm rounded-[10px] w-fit
							bg-gradient-to-t from-[#22eff7]/20 dark:from-[#22eff7]/35 from-0% to-transparent to-100% mx-1"
							>
								docs
							</a>

							<a
								ata-astro-prefetch="viewport"
								href="/components"
								class="px-2 py-1 text-[17px] shadow-sm rounded-[10px] w-fit
						bg-gradient-to-t from-[#f7228a]/20 dark:from-[#f7228a]/50 from-0% to-transparent to-100% mx-1"
							>
								components
							</a>

							<a
								ata-astro-prefetch="viewport"
								href="/blogs"
								class="px-2 py-1 text-[17px] shadow-sm rounded-[10px] w-fit
					bg-gradient-to-t from-foreground/10 dark:from-foreground/30 from-0% to-transparent to-100% mx-1"
							>
								blogs
							</a>

							pages are powered by the whitepapper <a
								class="underline hover:text-muted-foreground inline-block"
								href="/docs/dev-api/overview">dev api</a
							>.
							<br />
							There's simply isn't any better alternative
						</p>

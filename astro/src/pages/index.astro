									<h3 class="text-[16px] font-[460]">
										Self host guide
									</h3>
									<p
										class="mt-1 text-[11px] text-muted-foreground"
									>
										Whitepapper is open-sourced for schizo
										users.
									</p>

									<img
										src="/appLogo.png"
										class="h-[22px] w-[22px] absolute bottom-3 right-3 z-2"
									/>
								</div>
							</div>

							<p class="flex items-center gap-2">
								Read the docs <ArrowRight size={17} />
							</p>

		</section>

		<!-- <div class="px-5 md:px-15">
		<div
			class="md:mt-12 md:mb-27 mt-4 mb-17 grid grid-cols-2 md:flex w-full mx-auto gap-3 md:justify-between"
			style={{ maxWidth: `${MAX_LANDING_PAGE_WIDTH}px` }}
		>
			{
				featuresDivs.slice(0, 4).map((item) => (
					<div class="flex flex-col flex-1 gap-2 p-3 transition-all duration-300 hover:bg-card">
						<div class="flex items-center gap-3">
							<item.icon size={19} />
							<h2 class="text-[17px] font-[450]">{item.title}</h2>
						</div>
						<p class="text-sm text-foreground">
							{item.description}
						</p>
					</div>
				))
			}
		</div>
	</div> -->

		<section
			class="mt-10 mx-auto flex w-full flex-col px-5 md:px-15"
			aria-label="Product highlights"
		>
			<div
				class="w-full mx-auto mt-18 md:mt-40"
				style={{ maxWidth: `${MAX_LANDING_PAGE_WIDTH}px` }}
			>
				<h2 class="text-[34px] md:text-[40px] font-[500]">
					Fast worldwide
				</h2>
				<p class="mt-1 md:text-[19px] text-muted-foreground">
					Whitepapper is cached at edge using <span
						class="text-[#F48120] px-[2px]">cloudflare</span
					> CDN to reach users at
					<span class="font-[450] text-foreground">~ 100ms</span><br
					/>
					No confirugations needed.
				</p>

				<div class="relative mt-5">
					<img
						src="/appLogo.png"
						class="object-contain h-[14px] w-[14px] md:h-[20px] md:w-[20px] z-[2] absolute top-[6%] left-[10%]"
					/>
					<img
						src="/appLogo.png"
						class="object-contain h-[14px] w-[14px] md:h-[20px] md:w-[20px] z-[2] absolute top-[32%] left-[25%]"

---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";

import HeroDashboardLight from "@/assets/landingPage/hero_light.png";
import MetatagsEditorLight from "@/assets/landingPage/metatags_editor_light.png";
import BlueBgPattern from "@/assets/landingPage/blueBgPattern.jpg";
import LandingArticleList from "@/components/landing/LandingArticleList.astro";

import IntegrationsSection from "@/components/integrations-4";
import FAQs from "@/components/faqs-2";

import BlogsPageImg from "@/assets/landingPage/blogsPage.png";

const featuredArticles = [
	{
		title: "How to Write Content That AI Assistants Actually Quote",
		readTime: "6 min read",
		href: "/abhraneeldhar7/paper-20491f39-fcff-4683-9c01-d856dab87b9f",
	},
	{
		title: "How to Make Your Brand Recognizable to AI Systems",
		readTime: "1 min read",
		href: "/abhraneeldhar7/paper-5846b146-e7a0-424f-8eff-2818b695fe1e",
	},
	{
		title: "GEO: The Complete Guide to Showing Up in AI Search Results",
		readTime: "1 min read",
		href: "/abhraneeldhar7/paper-a396d657-361a-4392-bf8f-819043c1f11b",
	},
];

const homeFaqs = [
	{
		question: "What is Whitepapper?",
		answer: "Whitepapper is a markdown-first content platform for developers who want one source of truth for public pages, docs, blog posts, and API-backed content reuse.",
	},
	{
		question: "Who is Whitepapper for?",
		answer: "Whitepapper is built for solo developers, indie builders, technical writers, and small teams who want a practical publishing workflow without a bloated CMS.",
	},
	{
		question: "How does Whitepapper help SEO and AI visibility?",
		answer: "Whitepapper keeps metadata, canonical rules, public pages, schema, sitemaps, and LLM-facing files close to the content so search engines and AI systems can understand the same page clearly.",
	},
];

const homeExploreLinks = [
	{
		href: "/features",
		title: "Features",
		description:
			"See the core product pages for the Content API, distribution flow, metadata workflow, and public pages.",
	},
	{
		href: "/use-cases",
		title: "Use Cases",
		description:
			"Explore how Whitepapper fits developer blogs, portfolio frontends, and docs-plus-updates workflows.",
	},
	{
		href: "/pricing",
		title: "Pricing",
		description:
			"Review the current free plan and the machine-readable pricing file published for AI agents.",
	},
	{
		href: "/compare/whitepapper-vs-ghost",
		title: "Compare",
		description:
			"Compare Whitepapper with Ghost, Hashnode, and a Dev.to-only workflow without leaving the site.",
	},
	{
		href: "/glossary/llms-txt",
		title: "Glossary",
		description:
			"Read plain-English definitions for llms.txt, canonical URLs, content APIs, and programmatic SEO.",
	},
];

Astro.response.headers.set(
	"Cache-Control",
	"public, max-age=600, s-maxage=3600, stale-while-revalidate=86400",
);
---

<Layout reserveNavSpace={false}>
	<main class="relative mb-20 overflow-hidden" aria-label="Whitepapper home">
		<div class="mx-auto w-full">
			<div
				class="absolute left-[-80%] top-[3%] z-[-1] h-[10px] w-[700px] md:w-[1200px] rotate-[40deg] rounded-[50%] bg-foreground blur-[40px] dark:blur-[45px] md:left-[-30%] md:top-[-2%]"
				aria-hidden="true"
			>
			</div>
			<div
				class="absolute left-[-45%] top-[0%] z-[-1] h-[8px] w-[700px] md:w-[1200px] rotate-[40deg] rounded-[50%] bg-foreground blur-[40px] dark:blur-[45px] md:left-[-50%] md:top-[-3%]"
				aria-hidden="true"
			>
			</div>

			<section
				class="relative flex flex-col items-start justify-start pt-28 md:pt-30 h-full overflow-hidden"
				aria-labelledby="home-hero-title"
			>
				<div
					class="px-5 md:px-15 pb-[50px] mx-auto w-full max-w-[1500px]"
				>
					<h1
						id="home-hero-title"
						class="heroText text-[50px] md:text-[60px] flex md:flex-row flex-col md:gap-4 font-[450]"
					>
						<span>SEO first</span><span> content engine</span>
					</h1>

					<div
						class="my-4 space-y-2 text-[18px] text-muted-foreground md:w-[700px]"
					>
						<p class="heroText" style="animation-delay: 0.25s;">
							Whitepapper is a SEO-enforced content platform for
							developers who want one writing workflow for blogs,
							docs, updates, public pages, and API-backed
							frontends.<br /> <strong class="font-[450]">Own everything, distribute everywhere.</strong>
						</p>
					</div>

					<!-- <div class="flex gap-2 items-center justify-center w-full mt-5">
			<p class="text-[12px]">Not backed by</p>
			<div
			class="bg-[#fb6518] text-[white] text-[11px] font-[400] leading-[12px] w-[20px] h-[20px] flex items-center justify-center"
			>
			Y
			</div>
			</div> -->

					<div
						class="heroText mt-8 relative p-3 md:p-15 overflow-hidden md:rounded-[30px] rounded-[20px] h-full border shadow-md"
						style="animation-delay: 0.3s; animation-duration: 0.8s;"
					>
						<Image
							src={BlueBgPattern}
							alt="Green pattern background"
							class="absolute left-0 top-0 z-[-1] h-full w-full"
							loading="eager"
							quality={60}
						/>
						<Image
							src={HeroDashboardLight}
							alt="Whitepapper dashboard preview"
							class="h-fit w-full rounded-[10px]"
							loading="eager"
							fetchpriority="high"
						/>
					</div>
				</div>

				<div
					class="heroText absolute bottom-[5%] md:bottom-[25%] left-[50%] z-[-1] h-[110vw] w-[200vw] translate-x-[-50%] translate-y-[54%] overflow-hidden rounded-[50%] md:w-[150vw] md:translate-y-[85%] ease-in"
					style="animation-delay: 0.5s;"
				>
					<div
						class="h-[110vw] w-full rounded-[50%] border-[5px] border-foreground/80 blur-[20px]"
						aria-hidden="true"
					>
					</div>
				</div>
			</section>

			<p class="px-5 md:px-15 text-center my-5 mx-auto">
				The internet was yours first.
			</p>

			<section
				class="mt-14 mx-auto flex w-full max-w-[1500px] flex-col gap-15 md:gap-40 px-5 md:px-15"
				style="content-visibility:auto; contain-intrinsic-size: 1800px;"
				aria-label="Product highlights"
			>
				<div
					class="flex w-full flex-col-reverse gap-6 md:flex-row md:items-start md:gap-20"
				>
					<div class="flex-1">
						<div
							class="relative h-full w-full overflow-hidden rounded-[18px] md:rounded-[36px] p-3 md:p-8"
						>
							<Image
								src={BlueBgPattern}
								alt="Green pattern background"
								class="absolute left-0 top-0 z-[-1] h-full w-full"
								loading="lazy"
								quality={70}
								decoding="async"
							/>
							<Image
								src={MetatagsEditorLight}
								alt="Editor preview"
								class="h-full w-full object-cover rounded-[8px] md:rounded-[12px]"
								loading="lazy"
								decoding="async"
							/>
						</div>

						<LandingArticleList
							items={featuredArticles}
							className="md:hidden mt-5"
						/>
					</div>

					<div class="md:flex-1">
						<div>
							<h2 class="text-[30px] font-[450]">
								SEO defaults, out of the box
							</h2>
							<p
								class="mt-1 text-[17px] text-muted-foreground leading-[1.7em]"
							>
								Every paper you publish on Whitepapper gets
								title tags, meta descriptions, canonical URLs,
								and Open Graph metadata generated automatically.
								No SEO plugin, no manual fields, no forgetting.
								Your content is search-ready from the moment you
								hit publish.<br />
								<span class="font-[550]">
									The algorithm never believed in you, we do.
								</span>
							</p>
						</div>
						<LandingArticleList
							items={featuredArticles}
							className="mt-50 hidden md:block"
						/>
					</div>
				</div>

				<div
					class="flex md:flex-row flex-col gap-5 md:gap-10 my-5 items-center mx-auto max-w-[800px]"
				>
					<div
						class="flex-1 flex flex-col items-center text-center relative"
					>
						<div
							class="h-[30px] dark:h-[10px] w-[300px] rotate-[-10deg] rounded-[50%] bg-[#faae40] dark:blur-[45px] blur-[60px] absolute z-[-1] top-2"
						>
						</div>
						<h3 class="font-[600] text-[40px]">~ 100ms</h3>
						<p class="text-[16px] text-muted-foreground">
							Accross the globe
						</p>
					</div>
					<div
						class="h-[80px] hidden md:block w-[1px] bg-foreground/50"
					>
					</div>
					<div class="flex-1">
						<p class="text-center text-[16px] leading-[1.8em]">
							Whitepapper's API and public pages are cached at the
							edge using Cloudflare Workers. Whether your reader
							is in Mumbai or Munich, content loads in under
							100ms. No configurations needed.
						</p>
					</div>
				</div>

				<div class="">
					<div
						class="flex md:flex-row flex-col gap-3 justify-between items-start"
					>
						<h2
							class="md:flex-1 text-[30px] md:text-[40px] font-[450]"
						>
							Make your sites searchable
						</h2>
						<p
							class="md:flex-1 text-muted-foreground md:text-[20px] text-[16px]"
						>
							Every project gets a scoped API key. Use it to pull
							your papers, collections, and project data directly
							into your portfolio, personal site, or any frontend
							you're building. Read-only, fast, and safe to expose
							publicly.
						</p>
					</div>
					<div
						class="mt-8 md:mt-15 relative p-3 md:p-15 overflow-hidden md:rounded-[30px] rounded-[20px] h-full border shadow-md"
					>
						<Image
							src={BlueBgPattern}
							alt="Green pattern background"
							class="absolute left-0 top-0 z-[-1] h-full w-full"
							loading="lazy"
							quality={70}
							decoding="async"
						/>
						<Image
							src={BlogsPageImg}
							alt="Blogs page preview"
							class="h-fit w-full rounded-[10px]"
							loading="lazy"
							decoding="async"
						/>
					</div>
					<a href="/docs" class="w-fit">
						<p
							class="text-[14px] text-muted-foreground my-4 text-center"
						>
							Read the API docs
						</p>
					</a>
				</div>

				<!-- <section
					class="mt-[20px] mb-[70px] flex flex-col items-center gap-6"
					style="content-visibility:auto; contain-intrinsic-size: 360px;"
					aria-labelledby="home-trusted-logos"
				>
					<h2 class="text-[19px] text-muted-foreground">
						<span id="home-trusted-logos"
							>Look at these logos lmfao</span
						>
					</h2>
					<div
						class="flex gap-x-7 gap-y-5 grayscale flex-wrap justify-center items-center dark:invert"
					>
						<Image
							src={OpenAILogo}
							alt="OpenAI logo"
							class="h-[30px] w-fit opacity-[0.5]"
							loading="lazy"
							decoding="async"
						/>
						<Image
							src={GoogleLogo}
							alt="Google logo"
							class="h-[30px] w-fit"
							loading="lazy"
							decoding="async"
						/>
						<Image
							src={AudiLogo}
							alt="Audi logo"
							class="h-[30px] w-fit opacity-[0.5]"
							loading="lazy"
							decoding="async"
						/>
						<Image
							src={CursorLogo}
							alt="Cursor logo"
							class="h-[30px] w-fit opacity-[0.5]"
							loading="lazy"
							decoding="async"
						/>
						<Image
							src={TeslaLogo}
							alt="Tesla logo"
							class="h-[30px] w-fit opacity-[0.5]"
							loading="lazy"
							decoding="async"
						/>
					</div>
				</section> -->

				<IntegrationsSection />

				<section class="space-y-4">
					<div
						class="flex md:flex-row flex-col md:items-end md:justify-between gap-3"
					>
						<div>
							<h2 class="text-[30px] md:text-[40px] font-[450]">
								Explore the product
							</h2>
							<p
								class="mt-2 text-[16px] text-muted-foreground max-w-[760px]"
							>
								These pages are the clearest path through
								Whitepapper if you are evaluating the workflow,
								the API, or the SEO and GEO model.
							</p>
						</div>
						<a
							href="/docs"
							class="text-[14px] text-muted-foreground hover:text-foreground"
							>Browse documentation</a
						>
					</div>
					<div
						class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-5 gap-3"
					>
						{
							homeExploreLinks.map((item) => (
								<a
									href={item.href}
									class="rounded-[18px] p-4 hover:bg-muted/30 transition-all duration-200"
								>
									<h3 class="text-[17px] font-[520]">
										{item.title}
									</h3>
									<p class="mt-2 text-[14px] leading-[1.7em] text-muted-foreground">
										{item.description}
									</p>
								</a>
							))
						}
					</div>
				</section>

				<section class="space-y-4">
					<FAQs
						client:idle
						items={homeFaqs}
						title="FAQ"
						description="A quick overview of what Whitepapper is, who it serves, and why the public page layer matters."
					/>
				</section>
			</section>
		</div>
	</main>
</Layout>

<style>
	.heroText {
		animation: fadeInUp 0.5s ease-out forwards;
		animation-fill-mode: both;
	}

	@keyframes fadeInUp {
		from {
			opacity: 0;
			transform: translateY(30px);
		}

		to {
			opacity: 1;
			transform: translateY(0);
		}
	}
</style>

									class="relative rounded-b-[45px] overflow-hidden h-full"
								>
									<img
										src={chatgpt_mobile.src}
										class="h-full absolute w-full bottom-0 left-0 right-0 object-bottom object-cover"
									/>
								</div>
							</div>
						</div>
					</div>

					<div
						class="md:flex-1 overflow-hidden relative rounded-[20px] md:rounded-[30px]"
					>
						<img
							src={BlueBgPattern.src}
							class="absolute z-[-1] top-0 left-0 h-full w-full"
						/>
						<img
							src={vscode_mcp.src}
							class="translate-y-5 -translate-x-5 md:translate-y-15 md:-translate-x-15 rounded-[10px]"

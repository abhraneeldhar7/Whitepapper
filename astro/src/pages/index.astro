										class="rounded-tl-[15px] rounded-bl-[15px] border-r bg-[#151515] h-full w-[20px]"
									>
									</div>
								</div>
								<div
									class="h-full flex-1 bg-card relative rounded-tr-[5px] rounded-br-[5px] p-3 pt-7"
								>

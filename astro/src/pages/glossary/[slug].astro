---
import SiteContentPaperPage from "@/components/site/SiteContentPaperPage.astro";
import { buildBlogPaperMetadata, buildPaperSeoConfig } from "@/metadata/dynamic";
import { fetchDevPaperBySlug } from "@/lib/api/contentFetcher";

const pageSlug = Astro.params.slug as string;
const normalizedSlug = pageSlug.trim().toLowerCase();
const siteUrl = String(import.meta.env.PUBLIC_SITE_URL ?? "")
  .trim()
  .replace(/\/+$/, "");
const paperSlugByRouteSlug: Record<string, string> = {
  "content-api": "glossary-content-api",
};

if (pageSlug !== normalizedSlug) {
  return Astro.redirect(`/glossary/${normalizedSlug}`, 301);
}

Astro.response.headers.set(
  "Cache-Control",
  "public, max-age=300, s-maxage=300, stale-while-revalidate=300",
);
Astro.response.headers.set(
  "CDN-Cache-Control",
  "public, max-age=300, stale-while-revalidate=300",
);

const resolvedPaperSlug = paperSlugByRouteSlug[normalizedSlug] ?? normalizedSlug;
const { paper } = await fetchDevPaperBySlug(resolvedPaperSlug);

if (resolvedPaperSlug === normalizedSlug && paper.slug !== normalizedSlug) {
  return Astro.redirect(`/glossary/${paper.slug}`, 301);
}

const resolvedSiteUrl = siteUrl || Astro.url.origin.replace(/\/+$/, "");
const metadata = {
  ...buildBlogPaperMetadata({ paper, siteUrl: resolvedSiteUrl }),
  canonical: `${resolvedSiteUrl}/glossary/${normalizedSlug}`,
};

const seo = buildPaperSeoConfig(metadata, {
  schemaType: "Article",
  breadcrumbItems: [
    {
      position: 1,
      name: "Glossary",
      item: `${resolvedSiteUrl}/glossary`,
    },
    {
      position: 2,
      name: metadata.headline,
      item: metadata.canonical,
    },
  ],
});
---

<SiteContentPaperPage
  paper={paper}
  metadata={metadata}
  parentHref="/glossary"
  parentLabel="Glossary"
  seo={seo}
/>


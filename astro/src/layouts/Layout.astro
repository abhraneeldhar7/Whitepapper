---
import Footer from "@/components/footer.astro";
import SiteTopNav from "@/components/site/SiteTopNav.astro";
import { Toaster } from "@/components/ui/sonner";
import "../styles/global.css";

interface Props {
  hideFooter?: boolean;
  title?: string;
  description?: string;
  image?: string;
  noindex?: boolean;
  showSiteNav?: boolean;
  reserveNavSpace?: boolean;
}

const {
  hideFooter = false,
  title,
  description,
  image,
  noindex = false,
  showSiteNav = true,
  reserveNavSpace = true,
} = Astro.props as Props;
const themeCookie = Astro.cookies.get("theme")?.value ?? null;
const isDarkTheme = themeCookie === "dark";
const pathname = Astro.url.pathname;

const pathToTitle = (path: string) => {
  if (path === "/") return "Whitepapper";
  const parts = path
    .split("/")
    .filter(Boolean)
    .map((segment) =>
      segment
        .split("-")
        .map((word) => word.charAt(0).toUpperCase() + word.slice(1))
        .join(" "),
    );
  return `${parts.join(" | ")} | Whitepapper`;
};

const siteTitle = title ?? pathToTitle(pathname);
const siteDescription =
  description ??
  "Whitepapper is an SEO-first content engine to create, manage, and distribute content with API support and publishing workflows.";
const siteImage = image ?? `${Astro.url.origin}/appLogo.png`;
const canonical = `${Astro.url.origin}${pathname}`;
const locale = "en_US";
---

<!doctype html>
<html lang="en" class={isDarkTheme ? "dark" : ""} style={`color-scheme: ${isDarkTheme ? "dark" : "light"};`}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{siteTitle}</title>
    <meta name="description" content={siteDescription} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Whitepapper" />
    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={siteDescription} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content={locale} />
    <meta property="og:image" content={siteImage} />
    <meta property="og:image:alt" content={`${siteTitle} social preview`} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonical} />
    <meta name="twitter:title" content={siteTitle} />
    <meta name="twitter:description" content={siteDescription} />
    <meta name="twitter:image" content={siteImage} />
    <meta name="robots" content={noindex ? "noindex, nofollow" : "index, follow"} />
    <slot name="head" />
    <script is:inline>
      (() => {
        try {
          const storageKey = "theme";
          const root = document.documentElement;
          const stored = localStorage.getItem(storageKey);
          const cookieMatch = document.cookie.match(/(?:^|; )theme=([^;]+)/);
          const cookieTheme = cookieMatch ? decodeURIComponent(cookieMatch[1]) : null;
          const resolved = stored || cookieTheme || "light";
          const isDark = resolved === "dark";
          root.classList.toggle("dark", isDark);
          root.style.colorScheme = isDark ? "dark" : "light";
          if (stored !== resolved) {
            localStorage.setItem(storageKey, resolved);
          }
          if (cookieTheme !== resolved) {
            document.cookie = `theme=${resolved}; path=/; max-age=31536000`;
          }
        } catch {
          // ignore theme init errors (e.g. storage blocked)
        }
      })();
    </script>
  </head>
  <body>
    {showSiteNav && <SiteTopNav />}
    {showSiteNav && reserveNavSpace && <div class="h-[58px] w-full"></div>}
    <slot />
    {!hideFooter && <Footer />}
    <Toaster client:load   />
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
  }
</style>

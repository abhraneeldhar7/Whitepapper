---
import Footer from "@/components/footer.astro";
import SiteTopNav from "@/components/site/SiteTopNav.astro";
import { getPageSeoConfig, mergePageSeoConfig, type PageSeoConfig } from "@/metadata/pages";
import rootOgImageAsset from "@/assets/ogImages/root.png";
import { Toaster } from "@/components/ui/sonner";
import { ClientRouter } from "astro:transitions";
import "../styles/global.css";

interface Props {
  hideFooter?: boolean;
  title?: string;
  description?: string;
  image?: string;
  seo?: PageSeoConfig | null;
  noindex?: boolean;
  showSiteNav?: boolean;
  reserveNavSpace?: boolean;
  enableClientRouter?: boolean;
  enableToaster?: boolean;
}

const pathname = Astro.url.pathname;

const {
  hideFooter = false,
  title,
  description,
  image,
  seo = null,
  noindex = false,
  showSiteNav = true,
  enableClientRouter = pathname.startsWith("/dashboard") ||
    pathname.startsWith("/settings") ||
    pathname.startsWith("/write") ||
    pathname === "/login" ||
    pathname === "/sign-in" ||
    pathname === "/sign-up" ||
    pathname === "/welcome",
  enableToaster = pathname.startsWith("/dashboard") ||
    pathname.startsWith("/settings") ||
    pathname.startsWith("/write") ||
    pathname === "/login" ||
    pathname === "/sign-in" ||
    pathname === "/sign-up" ||
    pathname === "/welcome",
} = Astro.props as Props;
const themeCookie = Astro.cookies.get("theme")?.value ?? null;
const isDarkTheme = themeCookie === "dark";
const authHelpers = showSiteNav ? Astro.locals.auth() : null;
const token = authHelpers ? await authHelpers.getToken().catch(() => null) : null;
const isSignedIn = Boolean(token);
const routeSeoConfig = getPageSeoConfig(pathname);
const pageSeoConfig = mergePageSeoConfig(routeSeoConfig, seo);

const pathToTitle = (path: string) => {
  if (path === "/") return "Whitepapper";
  const parts = path
    .split("/")
    .filter(Boolean)
    .map((segment) =>
      segment
        .split("-")
        .map((word) => word.charAt(0).toUpperCase() + word.slice(1))
        .join(" "),
    );
  return `${parts.join(" | ")} | Whitepapper`;
};

const resolveAbsoluteUrl = (value?: string | null) => {
  const raw = String(value || "").trim();
  if (!raw) return "";

  const normalizedRaw = raw.replace(/^\/+/, "");
  if (
    normalizedRaw === "src/assets/orgImage.png" ||
    normalizedRaw === "src/assets/ogImage.png" ||
    normalizedRaw === "src/assets/ogImages/root.png"
  ) {
    const origin = Astro.url.origin.replace(/\/+$/, "");
    return `${origin}${rootOgImageAsset.src.startsWith("/") ? "" : "/"}${rootOgImageAsset.src}`;
  }

  if (raw.startsWith("http://") || raw.startsWith("https://")) {
    try {
      const parsed = new URL(raw);
      const currentOrigin = Astro.url.origin.replace(/\/+$/, "");
      const currentHost = new URL(currentOrigin).host;
      const isKnownPublicHost = parsed.host === "whitepapper.antk.in" || parsed.host === "www.whitepapper.antk.in";
      const isLocalRuntime = currentHost === "localhost:4321" || currentHost === "127.0.0.1:4321";

      // Keep source JSON static while ensuring local dev URLs stay local.
      if (isKnownPublicHost && isLocalRuntime) {
        return `${currentOrigin}${parsed.pathname}${parsed.search}${parsed.hash}`;
      }
    } catch {
      return raw;
    }
    return raw;
  }
  const origin = Astro.url.origin.replace(/\/+$/, "");
  return `${origin}${raw.startsWith("/") ? "" : "/"}${raw}`;
};

const siteTitle = pageSeoConfig?.title ?? title ?? pathToTitle(pathname);
const siteDescription =
  pageSeoConfig?.description ??
  description ??
  "Whitepapper is an SEO-first content engine to create, manage, and distribute content with API support and publishing workflows.";
const siteImage =
  resolveAbsoluteUrl(pageSeoConfig?.image) ||
  image ||
  `${Astro.url.origin}${rootOgImageAsset.src}`;
const canonical =
  resolveAbsoluteUrl(pageSeoConfig?.canonical) || `${Astro.url.origin}${pathname}`;
const robotsMeta = noindex
  ? "noindex, nofollow"
  : pageSeoConfig?.robots || "index, follow";
const keywordsMeta = pageSeoConfig?.keywords || "";
const ogTypeMeta = pageSeoConfig?.ogType || "website";
const siteNameMeta = pageSeoConfig?.siteName || "Whitepapper";
const localeMeta = pageSeoConfig?.locale || pageSeoConfig?.ogLocale || "en_US";
const authorMeta = pageSeoConfig?.author || "";
const ogTitleMeta = pageSeoConfig?.ogTitle || siteTitle;
const ogDescriptionMeta = pageSeoConfig?.ogDescription || siteDescription;
const ogUrlMeta = resolveAbsoluteUrl(pageSeoConfig?.ogUrl) || canonical;
const ogImageMeta = resolveAbsoluteUrl(pageSeoConfig?.ogImage) || siteImage;
const ogImageAltMeta = pageSeoConfig?.ogImageAlt || `${siteTitle} social preview`;
const ogImageWidthMeta = pageSeoConfig?.ogImageWidth;
const ogImageHeightMeta = pageSeoConfig?.ogImageHeight;
const ogPublishedTimeMeta = pageSeoConfig?.ogPublishedTime || "";
const ogModifiedTimeMeta = pageSeoConfig?.ogModifiedTime || "";
const ogAuthorUrlMeta = resolveAbsoluteUrl(pageSeoConfig?.ogAuthorUrl) || "";
const ogTagsMeta = Array.isArray(pageSeoConfig?.ogTags) ? pageSeoConfig.ogTags : [];
const twitterCardMeta = pageSeoConfig?.twitterCard || "summary_large_image";
const twitterTitleMeta = pageSeoConfig?.twitterTitle || siteTitle;
const twitterDescriptionMeta = pageSeoConfig?.twitterDescription || siteDescription;
const twitterImageMeta = resolveAbsoluteUrl(pageSeoConfig?.twitterImage) || ogImageMeta;
const twitterImageAltMeta = pageSeoConfig?.twitterImageAlt || ogImageAltMeta;
const twitterCreatorMeta = pageSeoConfig?.twitterCreator || "";
const twitterSiteMeta = pageSeoConfig?.twitterSite || "";
const articleSectionMeta = pageSeoConfig?.articleSection || "";
const articlePublishedTimeMeta =
  pageSeoConfig?.articlePublishedTime || ogPublishedTimeMeta;
const articleModifiedTimeMeta =
  pageSeoConfig?.articleModifiedTime || ogModifiedTimeMeta;
const articleAuthorMeta =
  resolveAbsoluteUrl(pageSeoConfig?.articleAuthor) || ogAuthorUrlMeta;
const articleTagsMeta = Array.isArray(pageSeoConfig?.articleTags)
  ? pageSeoConfig.articleTags
  : [];
const jsonLdItems = Array.isArray(pageSeoConfig?.jsonLd)
  ? pageSeoConfig?.jsonLd
  : pageSeoConfig?.jsonLd
    ? [pageSeoConfig.jsonLd]
    : [];
---

<!doctype html>
<html lang="en" class={isDarkTheme ? "dark" : ""} style={`color-scheme: ${isDarkTheme ? "dark" : "light"};`}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{siteTitle}</title>
    <meta name="description" content={siteDescription} />
    {authorMeta ? <meta name="author" content={authorMeta} /> : null}
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content={ogTypeMeta} />
    <meta property="og:site_name" content={siteNameMeta} />
    <meta property="og:title" content={ogTitleMeta} />
    <meta property="og:description" content={ogDescriptionMeta} />
    <meta property="og:url" content={ogUrlMeta} />
    <meta property="og:locale" content={localeMeta} />
    <meta property="og:image" content={ogImageMeta} />
    {ogImageWidthMeta ? <meta property="og:image:width" content={String(ogImageWidthMeta)} /> : null}
    {ogImageHeightMeta ? <meta property="og:image:height" content={String(ogImageHeightMeta)} /> : null}
    <meta property="og:image:alt" content={ogImageAltMeta} />
    {ogModifiedTimeMeta ? <meta property="og:updated_time" content={ogModifiedTimeMeta} /> : null}
    {ogPublishedTimeMeta ? <meta property="article:published_time" content={ogPublishedTimeMeta} /> : null}
    {articleModifiedTimeMeta ? <meta property="article:modified_time" content={articleModifiedTimeMeta} /> : null}
    {articleSectionMeta ? <meta property="article:section" content={articleSectionMeta} /> : null}
    {articleAuthorMeta ? <meta property="article:author" content={articleAuthorMeta} /> : null}
    {ogTagsMeta.map((tag) => <meta property="article:tag" content={tag} />)}
    {articleTagsMeta.map((tag) => <meta property="article:tag" content={tag} />)}
    <meta name="twitter:card" content={twitterCardMeta} />
    <meta name="twitter:url" content={canonical} />
    <meta name="twitter:title" content={twitterTitleMeta} />
    <meta name="twitter:description" content={twitterDescriptionMeta} />
    <meta name="twitter:image" content={twitterImageMeta} />
    <meta name="twitter:image:alt" content={twitterImageAltMeta} />
    {twitterCreatorMeta ? <meta name="twitter:creator" content={twitterCreatorMeta} /> : null}
    {twitterSiteMeta ? <meta name="twitter:site" content={twitterSiteMeta} /> : null}
    {keywordsMeta ? <meta name="keywords" content={keywordsMeta} /> : null}
    <meta name="robots" content={robotsMeta} />
    {
      jsonLdItems.map((item) => (
        <script
          is:inline
          type="application/ld+json"
          set:html={JSON.stringify(item)}
        />
      ))
    }
    <slot name="head" />
    {enableClientRouter ? <ClientRouter /> : null}
    <script is:inline>
      (() => {
        if (window.__wpReadyFlagsHooked) {
          return;
        }
        window.__wpReadyFlagsHooked = true;

        const READY_FLAGS = [
          "data-dashboard-ready",
          "data-project-workspace-ready",
          "data-collection-workspace-ready",
          "data-write-editor-ready",
        ];

        const clearReadyFlags = () => {
          const root = document.documentElement;
          for (const flag of READY_FLAGS) {
            root.removeAttribute(flag);
          }
        };

        document.addEventListener("astro:before-preparation", clearReadyFlags);
        document.addEventListener("astro:before-swap", clearReadyFlags);
      })();
    </script>
    <script is:inline>
      (() => {
        try {
          const storageKey = "theme";
          const root = document.documentElement;
          const stored = localStorage.getItem(storageKey);
          const cookieMatch = document.cookie.match(/(?:^|; )theme=([^;]+)/);
          const cookieTheme = cookieMatch ? decodeURIComponent(cookieMatch[1]) : null;
          const resolved = stored || cookieTheme || "light";
          const isDark = resolved === "dark";
          root.classList.toggle("dark", isDark);
          root.style.colorScheme = isDark ? "dark" : "light";
          if (stored !== resolved) {
            localStorage.setItem(storageKey, resolved);
          }
          if (cookieTheme !== resolved) {
            document.cookie = `theme=${resolved}; path=/; max-age=31536000`;
          }
        } catch {
          // ignore theme init errors (e.g. storage blocked)
        }
      })();
    </script>
  </head>
  <body>
    {showSiteNav && <SiteTopNav isSignedIn={isSignedIn} />}
    <!-- {showSiteNav && reserveNavSpace && <div class="h-[58px] w-full"></div>} -->
    <slot />
    {!hideFooter && <Footer />}
    {enableToaster ? <Toaster client:load /> : null}
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
  }
</style>

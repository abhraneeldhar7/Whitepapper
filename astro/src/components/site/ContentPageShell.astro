---
import Layout from "@/layouts/Layout.astro";
import MarkdownRender from "@/components/ui/markdown-render/markdown-render";
import FAQs from "@/components/faqs-2";
import { LinearTableOfContent } from "@/components/ui/toc/linearTableOfContent";
import type { DetailPage, PageLink } from "@/lib/sitePages";

type Props = {
  page: Omit<DetailPage, "slug">;
  path: string;
  parentHref: string;
  parentLabel: string;
};

const { page, path, parentHref, parentLabel } = Astro.props as Props;
const contentContainerId = `content-${path.replace(/\W+/g, "-")}`;

const seo = {
  path,
  title: `${page.title} | Whitepapper`,
  description: page.description,
  canonical: path,
  robots: "index, follow",
  ogType: "website",
  ogTitle: `${page.title} | Whitepapper`,
  ogDescription: page.description,
  ogUrl: path,
  twitterCard: "summary_large_image",
  twitterTitle: `${page.title} | Whitepapper`,
  twitterDescription: page.description,
  jsonLd: [
    {
      "@context": "https://schema.org",
      "@type": "WebPage",
      name: page.title,
      description: page.description,
      url: `${Astro.url.origin}${path}`,
      isPartOf: {
        "@type": "WebSite",
        name: "Whitepapper",
        url: Astro.url.origin,
      },
    },
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      itemListElement: [
        {
          "@type": "ListItem",
          position: 1,
          name: "Home",
          item: Astro.url.origin,
        },
        {
          "@type": "ListItem",
          position: 2,
          name: parentLabel,
          item: `${Astro.url.origin}${parentHref}`,
        },
        {
          "@type": "ListItem",
          position: 3,
          name: page.title,
          item: `${Astro.url.origin}${path}`,
        },
      ],
    },
    ...(page.faq?.length
      ? [
          {
            "@context": "https://schema.org",
            "@type": "FAQPage",
            mainEntity: page.faq.map((item) => ({
              "@type": "Question",
              name: item.question,
              acceptedAnswer: {
                "@type": "Answer",
                text: item.answer,
              },
            })),
          },
        ]
      : []),
  ],
};
---

<Layout seo={seo}>
  <main class="mx-auto w-full px-4 py-10">
    <div class="flex items-start justify-between gap-10">
      <div class="hidden md:block w-[320px] shrink-0"></div>
      <div class="w-full max-w-[900px]">
        <div class="flex gap-2 items-center text-[15px]">
          <a
            href={parentHref}
            class="text-muted-foreground transition-all duration-300 hover:text-foreground"
            ><p>{page.eyebrow}</p></a
          >
          <p>/</p>
          <p>{page.title}</p>
        </div>

        <section class="mt-6 border-b border-border/70 pb-8">
          <h1
            class="mt-3 text-[32px] md:text-[42px] font-[500] leading-[1.15em]"
          >
            {page.title}
          </h1>
          <p
            class="mt-4 max-w-[760px] text-[17px] leading-[1.8em] text-muted-foreground"
          >
            {page.description}
          </p>
        </section>

        <section class="mt-8">
          <MarkdownRender
            content={page.body}
            contentContainerId={contentContainerId}
          />
        </section>

        {
          page.links?.length ? (
            <section class="mt-12">
              <h2 class="text-[18px] font-[520]">Related links</h2>
              <div class="mt-4 grid grid-cols-1 gap-3 md:grid-cols-3">
                {page.links.map((link: PageLink) => (
                  <a
                    href={link.href}
                    class="rounded-[6px] p-4 hover:bg-muted/30 transition-all duration-200"
                  >
                    <p class="text-[16px] font-[520]">{link.label}</p>
                    <p class="mt-2 text-[14px] leading-[1.7em] text-muted-foreground">
                      {link.description}
                    </p>
                  </a>
                ))}
              </div>
            </section>
          ) : null
        }

        {
          page.faq?.length ? (
            <section class="mt-12">
              <FAQs
                client:idle
                items={page.faq}
                title="FAQs"
                description="Common questions for this page."
              />
            </section>
          ) : null
        }
      </div>

      <aside class="hidden md:block w-[320px] shrink-0 sticky top-[100px]">
        <LinearTableOfContent
          client:idle
          offset={120}
          containerId={contentContainerId}
        />
      </aside>
    </div>
  </main>
</Layout>

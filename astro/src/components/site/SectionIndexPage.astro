---
import Layout from "@/layouts/Layout.astro";
import type { PageLink } from "@/lib/sitePages";

type Props = {
  eyebrow: string;
  title: string;
  description: string;
  path: string;
  links: PageLink[];
};

const { eyebrow, title, description, path, links } = Astro.props as Props;

const seo = {
  path,
  title: `${title} | Whitepapper`,
  description,
  canonical: path,
  robots: "index, follow",
  ogType: "website",
  ogTitle: `${title} | Whitepapper`,
  ogDescription: description,
  ogUrl: path,
  twitterCard: "summary_large_image",
  twitterTitle: `${title} | Whitepapper`,
  twitterDescription: description,
  jsonLd: [
    {
      "@context": "https://schema.org",
      "@type": "CollectionPage",
      name: title,
      description,
      url: `${Astro.url.origin}${path}`,
    },
  ],
};
---

<Layout seo={seo}>
  <main class="min-h-screen mx-auto w-full max-w-[1000px] px-4 py-10">
    <section class="pb-8">
      <h1 class="mt-3 text-[32px] md:text-[42px] font-[500] leading-[1.15em]">
        {title}
      </h1>
      <p
        class="mt-4 max-w-[760px] text-[17px] leading-[1.8em] text-muted-foreground"
      >
        {description}
      </p>
    </section>

    <section class="grid grid-cols-1 md:gap-3 md:grid-cols-2">
      {
        links.map((link) => (
          <a
            href={link.href}
            class="rounded-[6px] p-2 md:p-4 hover:bg-muted/30 transition-all duration-200"
          >
            <p class="text-[18px] font-[520]">{link.label}</p>
            <p class="mt-2 text-[14px] leading-[1.7em] text-muted-foreground">
              {link.description}
            </p>
          </a>
        ))
      }
    </section>
  </main>
</Layout>

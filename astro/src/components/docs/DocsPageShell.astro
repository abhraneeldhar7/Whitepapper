---
import Layout from "@/layouts/Layout.astro";
import PostRender from "@/components/pre_made_components/render/postPreview";
import DocsCopyButton from "@/components/docs/DocsCopyButton";
import DocsMobileNav from "@/components/docs/DocsMobileNav";
import { cn } from "@/lib/utils";
import { Label } from "../ui/label";

type Props = {
  markdown: string;
  currentPath: "/docs" | "/docs/best-practices" | "/docs/advanced";
};

type NavItem = {
  title: string;
  href: "/docs" | "/docs/best-practices" | "/docs/advanced";
};

const { markdown, currentPath } = Astro.props as Props;

const navItems: NavItem[] = [
  { title: "Quickstart", href: "/docs" },
  { title: "Best practices", href: "/docs/best-practices" },
  { title: "Advanced", href: "/docs/advanced" },
];

const lines = markdown.split("\n");
const firstLine = lines[0]?.trim() ?? "";
const headingMatch = firstLine.match(/^#\s+(.+)$/);
const pageTitle = headingMatch?.[1]?.trim() || "Docs";
const bodyMarkdown = headingMatch
  ? lines.slice(1).join("\n").trimStart()
  : markdown;
---

<Layout
  title={`${pageTitle} | Whitepapper`}
  description={`${pageTitle} documentation for Whitepapper.`}
>
  <div class="pb-5 md:pb-10 px-5">
    <div class="flex gap-10 justify-between">
      <aside class="hidden md:block w-[200px]">
        <nav class="sticky top-24" aria-label="Documentation navigation">
          <Label>Pages</Label>
          <ul class="mt-2 space-y-2">
            {
              navItems.map((item) => {
                const isActive = item.href === currentPath;
                return (
                  <li>
                    <a
                      href={item.href}
                      class={cn(
                        "block rounded-md px-3 py-2 text-sm transition-colors",
                        isActive
                          ? "bg-muted text-foreground font-medium"
                          : "text-muted-foreground hover:bg-muted/60 hover:text-foreground",
                      )}
                    >
                      {item.title}
                    </a>
                  </li>
                );
              })
            }
          </ul>
        </nav>
      </aside>

      <main
        class="max-w-[700px] w-full pt-15"
        aria-label={`${pageTitle} documentation content`}
      >
        <div
          class="flex justify-between items-center md:sticky md:top-[55px] md:mb-10 w-full fixed top-[50px] pl-2 pr-4 bg-background/80 md:bg-background backdrop-blur-[20px] z-10 left-0 py-1 md:py-2"
        >
          <div class="flex gap-1 items-center">
            <div class="md:hidden">
              <DocsMobileNav
                client:load
                navItems={navItems}
                currentPath={currentPath}
              />
            </div>
            <h1 class="text-[20px] md:text-[32px] font-[500]">{pageTitle}</h1>
          </div>


          <DocsCopyButton client:load markdown={markdown} />
        </div>

        <PostRender content={bodyMarkdown} />
      </main>

      <aside class="hidden lg:block w-[200px]" aria-hidden="true"></aside>
    </div>
  </div>
</Layout>

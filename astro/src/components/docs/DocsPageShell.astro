---
import Layout from "@/layouts/Layout.astro";
import PostRender from "@/components/ui/markdown-render/markdown-render";
import MobileTableOfContent from "@/components/ui/toc/mobileTableOfContent";
import DocsCopyButton from "@/components/docs/DocsCopyButton";
import DocsMobileNav from "@/components/docs/DocsMobileNav";
import DocsSidebar from "@/components/docs/DocsSidebar.astro";
import { isMobileUserAgent } from "@/lib/userAgent";
import type {
  DocsNavSection,
  DocsPageEntry,
} from "@/content/docs/docsPagesStructure";
import type { PageSeoConfig } from "@/metadata/pages";
import { ChevronLeft, ChevronRight } from "lucide-react";
import { LinearTableOfContent } from "../ui/toc/linearTableOfContent";

type Props = {
  markdown: string;
  currentPath: string;
  pageTitle: string;
  pageDescription: string;
  pageSection: string;
  seo?: PageSeoConfig | null;
  navSections: DocsNavSection[];
  previousPage: DocsPageEntry | null;
  nextPage: DocsPageEntry | null;
};

const {
  markdown,
  currentPath,
  pageTitle,
  pageDescription,
  pageSection,
  seo = null,
  navSections,
  previousPage,
  nextPage,
} = Astro.props as Props;

const docsContentContainerId = "docs-page-content";
const userAgent = Astro.request.headers.get("user-agent");
const shouldRenderMobileToc = isMobileUserAgent(userAgent);
const pageTitleWithBrand = `${pageTitle} | Whitepapper`;
const breadcrumbItems = [
  {
    "@type": "ListItem",
    position: 1,
    name: "Docs",
    item: `${Astro.url.origin}/docs`,
  },
];

if (pageSection && pageSection !== "Getting Started") {
  breadcrumbItems.push({
    "@type": "ListItem",
    position: 2,
    name: pageSection,
    item: `${Astro.url.origin}/docs`,
  });
}

breadcrumbItems.push({
  "@type": "ListItem",
  position: breadcrumbItems.length + 1,
  name: pageTitle,
  item: `${Astro.url.origin}${currentPath}`,
});

const docsPageSeo = {
  path: currentPath,
  title: pageTitleWithBrand,
  description: pageDescription,
  canonical: currentPath,
  keywords:
    "whitepapper docs, developer documentation, technical docs, content publishing docs, api docs, seo docs",
  robots: "index, follow",
  ogType: "article",
  ogTitle: pageTitleWithBrand,
  ogDescription: pageDescription,
  ogUrl: currentPath,
  twitterCard: "summary_large_image",
  twitterTitle: pageTitleWithBrand,
  twitterDescription: pageDescription,
  jsonLd: [
    {
      "@context": "https://schema.org",
      "@type": "TechArticle",
      headline: pageTitle,
      description: pageDescription,
      articleSection: pageSection,
      url: `${Astro.url.origin}${currentPath}`,
      mainEntityOfPage: `${Astro.url.origin}${currentPath}`,
      isPartOf: {
        "@type": "CreativeWork",
        name: "Whitepapper Documentation",
        url: `${Astro.url.origin}/docs`,
      },
      author: {
        "@type": "Organization",
        name: "Whitepapper",
        url: Astro.url.origin,
      },
      publisher: {
        "@type": "Organization",
        name: "Whitepapper",
        url: Astro.url.origin,
        logo: {
          "@type": "ImageObject",
          url: `${Astro.url.origin}/appLogo.png`,
        },
      },
    },
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      itemListElement: breadcrumbItems,
    },
  ],
};
const resolvedSeo = seo ?? docsPageSeo;
---

<Layout
  title={pageTitleWithBrand}
  description={pageDescription}
  seo={resolvedSeo}
>
  <div class="pb-5 md:pb-10 px-4">
    <div class="flex gap-10 justify-between">
        {
        !shouldRenderMobileToc && (
          <DocsSidebar
            navSections={navSections}
            currentPath={currentPath}
            previousPage={previousPage}
            nextPage={nextPage}
          />
        )
      }

      <main
        class="max-w-[700px] w-full pt-14 md:pt-20"
        aria-label={`${pageTitle} documentation content`}
      >
        <div
          class="fixed top-[50px] md:top-[55px] left-0 w-full z-[4] flex justify-between items-center gap-10"
        >
          <div class="md:w-[300px] md:block hidden shrink-0"></div>

          <div
            class="flex w-full max-w-[700px] justify-between items-center gap-2 bg-background/85 backdrop-blur-[20px] px-[15px] md:px-[0px] py-2 md:py-4 z-[5]"
          >
            <div class="flex gap-1 items-center w-full">
              <div class="md:hidden">
                {
                  shouldRenderMobileToc && (
                    <DocsMobileNav
                      client:idle
                      navSections={navSections}
                      currentPath={currentPath}
                    />
                  )
                }
              </div>
              <div class="w-full h-[20px] md:h-[32px] relative">
                <h1
                  class="absolute left-0 top-1/2 -translate-y-1/2 right-0 text-[20px] md:text-[32px] truncate font-[500] leading-[1.5em]"
                >
                  {pageTitle}
                </h1>
              </div>
            </div>

            <DocsCopyButton client:idle markdown={markdown} />
          </div>

          <div class="md:w-[350px] md:block hidden shrink-0"></div>
        </div>

        <PostRender
          content={markdown}
          contentContainerId={docsContentContainerId}
        />

        <nav class="mt-7 pt-6" aria-label="Docs page pagination">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            {
              previousPage ? (
                <a
                  href={previousPage.route}
                  data-astro-prefetch="viewport"
                  class="rounded-lg border border-border/70 p-4 hover:bg-muted/70 transition-all duration-300 flex flex-col"
                >
                  <div class="flex gap-1 items-center  text-muted-foreground">
                    <ChevronLeft size={14} />
                    <p class="text-[12px]">Previous</p>
                  </div>
                  <p class="mt-4 text-[15px] font-[500] leading-tight">
                    {previousPage.title}
                  </p>
                </a>
              ) : (
                <div aria-hidden="true" />
              )
            }

            {
              nextPage ? (
                <a
                  href={nextPage.route}
                  data-astro-prefetch="viewport"
                  class="rounded-lg border border-border/70 p-4 hover:bg-muted/70 transition-all duration-300 flex flex-col items-end"
                >
                  <div class="flex gap-1 items-center  text-muted-foreground">
                    <p class="text-[12px]">Next</p>
                    <ChevronRight size={14} />
                  </div>
                  <p class="mt-4 text-[15px] font-[500] leading-tight">
                    {nextPage.title}
                  </p>
                </a>
              ) : (
                <div aria-hidden="true" />
              )
            }
          </div>
        </nav>
      </main>

      <aside class="hidden md:block w-[320px] z-[10]">
        {
          !shouldRenderMobileToc && (
            <div class="fixed top-[80px] w-[320px] right-10">
              <LinearTableOfContent
                client:load
                offset={125}
                containerId={docsContentContainerId}
              />
            </div>
          )
        }
      </aside>
    </div>
  </div>

  {
    shouldRenderMobileToc ? (
      <MobileTableOfContent
        client:load
        contentContainerId={docsContentContainerId}
        topOffset={110}
      />
    ) : null
  }
</Layout>

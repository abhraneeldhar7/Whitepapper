---
import { Button } from "@/components/ui/button";
import MarkdownRender from "@/components/ui/markdown-render/markdown-render";

type PrevNextLink = {
  href: string;
  label: string;
};

interface Props {
  componentName: string;
  title: string;
  description: string;
  markdown: string;
  contentContainerId: string;
  previous?: PrevNextLink | null;
  next?: PrevNextLink | null;
}

const {
  componentName,
  title,
  description,
  markdown,
  contentContainerId,
  previous = null,
  next = null,
} = Astro.props;
---

<main class="mx-auto min-h-screen w-full max-w-[1400px] px-[15px] pt-8 pb-20">
  <div class="flex flex-col gap-8 md:flex-row md:gap-10">
    <div class="hidden md:block md:flex-1" aria-hidden="true"></div>

    <div class="md:flex-3 min-w-0">
      <p class="text-[13px] uppercase tracking-[0.22em] text-muted-foreground">
        <a href="/components" class="underline underline-offset-4 hover:text-foreground">Components</a>
        <span class="mx-2">/</span>
        <span>{componentName}</span>
      </p>

      <h1 class="mt-3 text-[30px] font-[500] leading-tight md:text-[42px]">{title}</h1>
      <p class="mt-3 max-w-[760px] text-[16px] leading-7 text-muted-foreground md:text-[17px]">{description}</p>

      <div class="mt-8 md:hidden">
        <slot name="mobile-preview" />
      </div>

      <div class="mt-8">
        <MarkdownRender content={markdown} contentContainerId={contentContainerId} />
      </div>

      <div class="mt-10 flex flex-wrap items-center justify-between gap-3 border-t pt-6">
        <div>
          {previous && (
            <a href={previous.href}>
              <Button variant="secondary">Previous: {previous.label}</Button>
            </a>
          )}
        </div>
        <div class="ml-auto">
          {next && (
            <a href={next.href}>
              <Button variant="secondary">Next: {next.label}</Button>
            </a>
          )}
        </div>
      </div>
    </div>

    <aside class="hidden md:block md:flex-1 min-w-0">
      <slot name="desktop-preview" />
    </aside>
  </div>
</main>

---
import PostRender from "./pre_made_components/render/postPreview";
import { LinearTableOfContents } from "./tableOfContents/desktopLinearToc";

type LegalSection = {
  title: string;
  content: string;
};

type Props = {
  title: string;
  summary: string;
  effectiveDate: string;
  sections: LegalSection[];
  eyebrow?: string;
  altHref?: string;
  altLabel?: string;
};

const { title, summary, effectiveDate, sections } = Astro.props;

function slugify(value: string) {
  return value
    .toLowerCase()
    .replace(/[^a-z0-9\s-]/g, "")
    .trim()
    .replace(/\s+/g, "-");
}

const containerId = "legal-document-container";
---

<div class="min-h-screen bg-background text-foreground">
  <div class="mx-auto w-full max-w-6xl px-6 py-8 md:px-10 md:py-10">
    <div class="flex items-center justify-between pb-5">
      <a
        href="/"
        class="text-sm w-fit text-muted-foreground hover:text-foreground flex items-center gap-2"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="m15 18-6-6 6-6"></path>
        </svg>
        Home
      </a>

      <p class="text-sm text-muted-foreground">{effectiveDate}</p>
    </div>

    <header class="py-10 md:py-14">
      <h1 class="mt-3 max-w-3xl text-4xl leading-[1.05] md:text-6xl">
        {title}
      </h1>
      <p
        class="mt-5 max-w-2xl text-sm leading-relaxed text-muted-foreground md:text-base"
      >
        {summary}
      </p>
    </header>

    <div class="grid gap-8 border-t border-border pt-12 md:grid-cols-12">
      <aside class="md:col-span-4">
        <div class="md:sticky md:top-20">
          <LinearTableOfContents offset={64} client:load containerId={containerId} />
        </div>
      </aside>

      <main class="space-y-3 md:col-span-8" id={containerId}>
        {
          sections.map((section, index) => {
            const id = slugify(section.title);
            return (
              <article
                id={id}
                class="border border-border/70 bg-card dark:bg-card/30 p-5 md:p-6"
              >
                <p class="text-[11px] uppercase tracking-[0.11em] text-muted-foreground">
                  Section {index + 1}
                </p>
                <h2 class="mt-2 text-2xl leading-tight md:text-3xl">
                  {section.title}
                </h2>
                {/* <p class="mt-3 whitespace-pre-line text-sm leading-relaxed text-muted-foreground md:text-base">
                  {section.content}
                </p> */}
                <PostRender content={section.content} />
              </article>
            );
          })
        }
      </main>
    </div>
  </div>
</div>
